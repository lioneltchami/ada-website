{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ada-website",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "compatibility_date": "2026-05-09",
  "assets": {
    "directory": "dist/client"
  },
  "observability": {
    "enabled": true
  },
  "routes": [
    { "pattern": "apotidev.org/*", "zone_name": "apotidev.org" },
    { "pattern": "www.apotidev.org/*", "zone_name": "apotidev.org" }
  ],
  "workers_dev": true
}
