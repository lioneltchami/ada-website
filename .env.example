# Sanity CMS
SANITY_PROJECT_ID=your-sanity-project-id
SANITY_DATASET=production
SANITY_API_TOKEN=

# Supabase
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Stripe (get from https://dashboard.stripe.com/test/apikeys)
# Test mode keys start with pk_test_ and sk_test_
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Site
PUBLIC_SITE_URL=https://apotidev.org

# Umami Analytics (get from https://cloud.umami.is)
PUBLIC_UMAMI_WEBSITE_ID=
PUBLIC_UMAMI_URL=https://cloud.umami.is