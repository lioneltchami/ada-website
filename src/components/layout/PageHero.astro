---
interface Props {
  title: string;
  subtitle?: string;
  badge?: string;
  compact?: boolean;
}

const { title, subtitle, badge, compact = false } = Astro.props;
---

<section
  class:list={[
    "relative overflow-hidden text-white",
    compact ? "py-16 md:py-20" : "py-24 md:py-32",
    "bg-gradient-to-br from-primary-800 via-primary-700 to-primary-900",
  ]}
>
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-20 left-10 w-72 h-72 bg-primary-300 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-10 w-96 h-96 bg-accent-300 rounded-full blur-3xl"></div>
  </div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    {badge && (
      <span class="inline-block px-4 py-1.5 mb-4 text-sm font-medium bg-white/10 backdrop-blur-sm rounded-full border border-white/20">
        {badge}
      </span>
    )}
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold leading-tight">{title}</h1>
    {subtitle && <p class="mt-4 text-lg md:text-xl text-white/80 max-w-2xl mx-auto leading-relaxed">{subtitle}</p>}
    <slot />
  </div>
</section>
