---
interface Props {
  id?: string;
  class?: string;
  background?: "white" | "gray" | "primary" | "dark";
  padding?: "sm" | "md" | "lg";
}

const {
  id,
  class: className = "",
  background = "white",
  padding = "md",
} = Astro.props;

const bg = {
  white: "bg-white",
  gray: "bg-gray-50",
  primary: "bg-primary-50",
  dark: "bg-gradient-to-br from-primary-700 via-primary-800 to-primary-900 text-white",
};

const pad = {
  sm: "py-8 md:py-12",
  md: "py-12 md:py-16",
  lg: "py-16 md:py-24",
};
---

<section id={id} class:list={[bg[background], pad[padding], className]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <slot />
  </div>
</section>
