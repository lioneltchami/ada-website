---
import Section from '../layout/Section.astro';
import type { Locale } from '../../i18n';
import type { YearDocumentGroup, ProjectDemographic } from '../../lib/project-archive';
import { demographicLabel, projectDisplayTitle } from '../../lib/project-archive';

interface DueDiligenceDoc {
  title: string;
  desc: string;
  link: string;
  external: boolean;
  /** Decorative emoji for card */
  icon?: string;
  /** CTA line (e.g. Open for internal pages, Download for PDFs) */
  action?: string;
}

interface Props {
  locale: Locale;
  labels: {
    annualReports: string;
    projectDocs: string;
    projectDocsIntro: string;
    funderDocs: string;
    funderDocsDesc: string;
    tor: string;
    financials: string;
    completionReport: string;
    download: string;
    openLink: string;
    annualReportForYear: string;
    projectsInYear: string;
    demographics: Record<ProjectDemographic, string>;
  };
  dueDiligenceDocs: DueDiligenceDoc[];
  yearGroups: YearDocumentGroup[];
  totalProjects: number;
}

const { locale, labels, dueDiligenceDocs, yearGroups, totalProjects } = Astro.props;
const latestYear = yearGroups[0]?.year;
---

<!-- Due diligence — card grid (scannable for funders) -->
<Section background="gray" padding="lg">
  <div class="max-w-5xl mx-auto">
    <div class="mb-8 max-w-3xl">
      <h2 class="text-3xl font-heading font-bold text-gray-900">{labels.funderDocs}</h2>
      <p class="text-gray-600 mt-2 leading-relaxed">{labels.funderDocsDesc}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {dueDiligenceDocs.map((doc) => (
        <a
          href={doc.link}
          target={doc.external ? '_blank' : '_self'}
          rel={doc.external ? 'noopener' : undefined}
          class="group flex gap-5 p-6 bg-white rounded-2xl border border-gray-200 hover:border-primary-200 hover:shadow-lg hover:shadow-primary-900/5 transition-all duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600"
        >
          <div
            class="w-14 h-14 rounded-2xl bg-gradient-to-br from-primary-50 to-primary-100/80 border border-primary-100 flex items-center justify-center shrink-0 group-hover:from-primary-100 group-hover:to-primary-50 transition-colors"
            aria-hidden="true"
          >
            <span class="text-2xl">{doc.icon ?? '📋'}</span>
          </div>
          <div class="min-w-0 flex-1 flex flex-col">
            <span class="font-bold text-gray-900 text-lg leading-snug group-hover:text-primary-800 transition-colors">
              {doc.title}
            </span>
            <span class="text-sm text-gray-600 mt-1.5 leading-relaxed">{doc.desc}</span>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-primary-700">
              {doc.action ?? labels.download}
              <span class="transition-transform group-hover:translate-x-0.5" aria-hidden="true">→</span>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Section>

<!-- Projects by year → demographic (demographics are styled labels, not headings — avoids dozens of h3s) -->
<Section background="white" padding="lg">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl font-heading font-bold text-gray-900">{labels.projectDocs}</h2>
    <p class="mt-1 text-sm text-gray-600">
      {labels.projectDocsIntro.replace('{count}', String(totalProjects))}
    </p>

    <div class="mt-6 space-y-3">
      {yearGroups.map((yearGroup) => (
        <details
          class="group rounded-xl border border-gray-200 bg-gray-50/40 open:bg-white open:shadow-sm"
          open={yearGroup.year === latestYear}
        >
          <summary class="flex flex-wrap items-center gap-x-3 gap-y-1 px-4 py-3 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
            <span class="font-heading font-bold text-gray-900">{yearGroup.year}</span>
            <span class="text-xs text-gray-500">
              {labels.projectsInYear.replace('{count}', String(yearGroup.projectCount))}
            </span>
            <span class="ml-auto text-gray-400 group-open:rotate-180 transition-transform" aria-hidden="true">▾</span>
          </summary>

          <div class="px-4 pb-4 pt-0 border-t border-gray-100">
            {yearGroup.annualReportPath && (
              <a
                href={yearGroup.annualReportPath}
                target="_blank"
                rel="noopener"
                class="mt-3 inline-flex items-center gap-2 text-sm font-medium text-primary-700 hover:text-primary-800"
              >
                <span aria-hidden="true">📊</span>
                {labels.annualReportForYear.replace('{year}', String(yearGroup.year))}
              </a>
            )}

            <div class="mt-4 space-y-5">
              {yearGroup.demographics.map((demoGroup) => (
                <div role="group" aria-label={demographicLabel(demoGroup.demographic, labels.demographics)}>
                  <p class="text-xs font-bold uppercase tracking-wider text-primary-700">
                    {demographicLabel(demoGroup.demographic, labels.demographics)}
                  </p>
                  <ul class="mt-2 space-y-2">
                    {demoGroup.projects.map((project) => (
                      <li class="rounded-lg border border-gray-100 bg-white px-3 py-2.5">
                        <p class="text-sm font-medium text-gray-900">
                          {projectDisplayTitle(project, locale)}
                        </p>
                        <p class="mt-1.5 flex flex-wrap gap-x-3 gap-y-1 text-xs">
                          <a
                            href={`/docs/projects/${project.slug}/tor.pdf`}
                            target="_blank"
                            rel="noopener"
                            class="text-primary-700 hover:underline"
                          >
                            {labels.tor}
                          </a>
                          <span class="text-gray-300" aria-hidden="true">·</span>
                          <a
                            href={`/docs/projects/${project.slug}/financial.pdf`}
                            target="_blank"
                            rel="noopener"
                            class="text-primary-700 hover:underline"
                          >
                            {labels.financials}
                          </a>
                          <span class="text-gray-300" aria-hidden="true">·</span>
                          <a
                            href={`/docs/projects/${project.slug}/report.pdf`}
                            target="_blank"
                            rel="noopener"
                            class="text-primary-700 hover:underline"
                          >
                            {labels.completionReport}
                          </a>
                        </p>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        </details>
      ))}
    </div>
  </div>
</Section>
