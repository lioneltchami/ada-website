---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Chatbot from '../components/islands/Chatbot';
import { getFaqResponses } from '../lib/sanity';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noIndex?: boolean;
}

const props = Astro.props;

let faqData: { keywords: string[]; response: string }[] = [];
try {
  const faqs = await getFaqResponses();
  if (faqs?.length) {
    faqData = faqs.map(f => ({ keywords: f.keywords, response: f.response }));
  }
} catch {}
---

<BaseLayout {...props}>
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:p-4 focus:bg-primary-600 focus:text-white focus:rounded"
  >
    Skip to main content
  </a>
  <Header />
  <main id="main-content">
    <slot />
  </main>
  <!-- Mobile floating donate button -->
  <a
    href="/donate"
    class="fixed bottom-4 right-4 z-50 sm:hidden flex items-center gap-2 px-4 py-3 text-sm font-semibold text-white bg-primary-600 rounded-full shadow-lg hover:bg-primary-700 transition-colors"
    aria-label="Donate"
  >
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
    </svg>
    Donate
  </a>
  <Footer />
  <Chatbot client:idle faqs={faqData} />
</BaseLayout>
