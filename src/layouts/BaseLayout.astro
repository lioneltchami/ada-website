---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noIndex?: boolean;
}

const {
  title,
  description,
  ogImage = "/og-image.svg",
  noIndex = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Apoti Development Association</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap"
      rel="stylesheet"
    />

    <meta name="theme-color" content="#15803d" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {Astro.url.pathname === '/' && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "NGO",
        "name": "Apoti Development Association",
        "alternateName": "ADA",
        "url": "https://apotidev.org",
        "description": "Faith-based charity empowering vulnerable communities in Cameroon",
        "foundingDate": "2021",
        "address": { "@type": "PostalAddress", "addressCountry": "CM" },
        "contactPoint": { "@type": "ContactPoint", "email": "info@apotidev.org", "telephone": "+237676282346", "contactType": "customer service" },
        "sameAs": ["https://facebook.com/apotidev", "https://instagram.com/apotidev", "https://twitter.com/apotidev"]
      })} />
    )}
    {import.meta.env.PUBLIC_UMAMI_WEBSITE_ID && (
      <script
        defer
        src={`${import.meta.env.PUBLIC_UMAMI_URL || 'https://cloud.umami.is'}/script.js`}
        data-website-id={import.meta.env.PUBLIC_UMAMI_WEBSITE_ID}
      />
    )}
    <ClientRouter />
  </head>
  <body>
    <slot />
  </body>
</html>
