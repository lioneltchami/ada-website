---
import PageLayout from "../layouts/PageLayout.astro";
import Section from "../components/layout/Section.astro";
import NewsletterSignup from '../components/islands/NewsletterSignup';
import { getImpactMetrics, getHomePage, getTestimonials, getProjects, type SanityImpactMetric, type SanityHomePage, type SanityProject, sanityImageUrl } from '../lib/sanity';

let heroImageUrl = '';
try {
  const projects = await getProjects();
  if (projects?.length) {
    const withImage = projects.find((p: SanityProject) => p.mainImage?.asset?._ref);
    if (withImage) heroImageUrl = sanityImageUrl(withImage.mainImage!.asset._ref, 1200);
  }
} catch {}

let stats = [
  { value: '200+', label: 'Lives Impacted' },
  { value: '5', label: 'Communities Served' },
  { value: '15+', label: 'Widows Supported' },
  { value: '5', label: 'Years of Service' },
];

try {
  const metrics = await getImpactMetrics();
  if (metrics?.length) {
    stats = metrics.map((m: SanityImpactMetric) => ({
      value: `${m.value}${m.suffix || ''}`,
      label: m.label,
    }));
  }
} catch {}

// Fallback content
let heroBadge = 'Faith-Based Charity \u00b7 Cameroon';
let heroHeadline = 'No Widow Should Have to Choose Between Food and School Fees';
let heroSubtitle = 'Since 2021, we\'ve helped 200+ widows, orphans, and young women in Cameroon move from crisis to self-sufficiency. 80\u00a2 of every dollar goes directly to programs.';
let missionHeading = 'Our Mission';
let missionBody = 'To provide holistic support to vulnerable communities in Cameroon through faith-based programs that address immediate needs while building long-term self-sufficiency.';
let missionCards = [
  { icon: '🤝', title: 'Widow Support', description: 'Financial aid, skills training, and community for widows rebuilding their lives.' },
  { icon: '📚', title: 'Education', description: 'School supplies, tuition support, and mentorship for orphaned children.' },
  { icon: '💪', title: 'Empowerment', description: 'Vocational training and microfinance for young women seeking independence.' },
];
let ctaHeading = 'Make a Difference Today';
let ctaBody = 'Every contribution helps us reach more vulnerable communities in Cameroon. Join us in building a brighter future.';

try {
  const page = await getHomePage();
  if (page) {
    heroBadge = page.heroBadge || heroBadge;
    heroHeadline = page.heroHeadline || heroHeadline;
    heroSubtitle = page.heroSubtitle || heroSubtitle;
    missionHeading = page.missionHeading || missionHeading;
    missionBody = page.missionBody || missionBody;
    if (page.missionCards?.length) missionCards = page.missionCards;
    ctaHeading = page.ctaHeading || ctaHeading;
    ctaBody = page.ctaBody || ctaBody;
  }
} catch {}

interface Testimonial {
  name: string;
  quote: string;
  location: string;
  program: string;
}

const fallbackTestimonials: Testimonial[] = [
  { name: 'Amina N.', quote: 'After my husband passed, I did not know how I would feed my children. ADA provided food packages and enrolled me in tailoring training. Today I run a small shop and can support my family on my own.', location: 'Bamenda', program: 'Widow Support Program' },
  { name: 'Marie F.', quote: 'ADA paid my school fees when my grandmother could not afford them. They gave me books, a uniform, and a mentor who checks on me every week. I want to become a nurse to help others.', location: 'Douala', program: 'Education for Orphans' },
  { name: 'Esther K.', quote: 'The skills training program taught me hairdressing. ADA even helped me get my first set of tools. Now I have regular clients and I am saving to open my own salon.', location: 'Yaoundé', program: 'Young Women Empowerment' },
];

let testimonials: Testimonial[] = fallbackTestimonials;
try {
  const data = await getTestimonials();
  if (data?.length) {
    testimonials = data.map((t: any) => ({
      name: t.name,
      quote: t.quote,
      location: t.location || '',
      program: t.program || '',
    }));
  }
} catch {}
---

<PageLayout
  title="Empowering Communities in Cameroon"
  description="Empowering vulnerable communities in Cameroon through faith-based programs supporting widows, orphans, and young women since 2021."
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden py-24 md:py-32 text-white">
    {heroImageUrl ? (
      <img src={heroImageUrl} alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
    ) : null}
    <div class="absolute inset-0 bg-gradient-to-br from-primary-900/90 via-primary-800/85 to-primary-900/90"></div>
    <div class="absolute inset-0 opacity-10" aria-hidden="true">
      <div class="absolute top-20 left-10 w-72 h-72 bg-primary-300 rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-10 w-96 h-96 bg-accent-300 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block px-4 py-1.5 mb-6 text-sm font-medium bg-white/10 backdrop-blur-sm rounded-full border border-white/20">
        {heroBadge}
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold leading-tight">
        {heroHeadline}
      </h1>
      <p class="mt-6 text-lg md:text-xl text-white/80 max-w-2xl mx-auto leading-relaxed">
        {heroSubtitle}
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/donate"
          class="inline-flex items-center px-6 py-3 text-base font-semibold text-primary-900 bg-white rounded-lg hover:bg-gray-100 transition-colors shadow-lg"
          data-umami-event="hero-donate-cta"
        >
          Donate Now
        </a>
        <a
          href="/projects"
          class="inline-flex items-center px-6 py-3 text-base font-semibold text-white border-2 border-white/30 rounded-lg hover:bg-white/10 transition-colors"
        >
          Our Projects
        </a>
      </div>
      <p class="mt-6 text-sm text-white/60 flex flex-wrap items-center justify-center gap-3">
        <span class="px-2.5 py-1 bg-white/10 rounded-full border border-white/20">200+ lives changed</span>
        <span class="px-2.5 py-1 bg-white/10 rounded-full border border-white/20">5 communities</span>
        <span class="px-2.5 py-1 bg-white/10 rounded-full border border-white/20">80% to programs</span>
      </p>
    </div>
  </section>

  <!-- Impact Stats -->
  <Section background="white" padding="md">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      {stats.map((stat, i) => (
        <div class="stat-animate" style={`animation-delay: ${i * 150}ms`}>
          <p class="text-3xl md:text-4xl font-bold text-primary-700">{stat.value}</p>
          <p class="mt-1 text-sm text-gray-600">{stat.label}</p>
        </div>
      ))}
    </div>
    <p class="mt-6 text-center text-sm text-gray-500">85% of our beneficiaries are women and girls · 5% admin overhead · <a href="/transparency" class="text-primary-600 hover:underline">View full transparency report</a></p>
  </Section>

  <!-- Campaign Progress -->
  <Section background="white" padding="sm">
    <div class="max-w-2xl mx-auto">
      <div class="p-6 bg-gradient-to-r from-primary-50 to-accent-50 rounded-2xl border border-primary-100">
        <div class="flex items-center justify-between mb-2">
          <h3 class="text-sm font-semibold text-gray-900">2026 Education Drive</h3>
          <span class="text-xs font-medium text-red-700 bg-red-50 px-2 py-0.5 rounded-full">Ends Sept 1, 2026</span>
        </div>
        <p class="text-xs text-gray-600 mb-3">Help us send 50 children back to school this September.</p>
        <div class="w-full h-3 bg-gray-200 rounded-full overflow-hidden" role="progressbar" aria-valuenow="27" aria-valuemin="0" aria-valuemax="100" aria-label="Campaign progress">
          <div class="h-full bg-gradient-to-r from-primary-500 to-primary-400 rounded-full transition-all" style="width: 27%"></div>
        </div>
        <div class="flex items-center justify-between mt-2">
          <span class="text-sm font-bold text-primary-700">$800 raised</span>
          <span class="text-xs text-gray-500">Goal: $3,000 · 47 donors</span>
        </div>
        <a href="/donate?project=education-drive" class="mt-4 block w-full text-center px-4 py-2.5 text-sm font-semibold text-white bg-secondary-500 rounded-lg hover:bg-secondary-600 transition-colors shadow-sm">
          Contribute to This Campaign
        </a>
      </div>
    </div>
  </Section>

  <!-- Mission Section -->
  <Section background="gray" padding="lg">
    <div class="relative">
      <!-- Floating photos (decorative, blurred/opacity) -->
      {heroImageUrl && (
        <>
          <div class="hidden lg:block absolute -left-4 top-8 w-32 h-44 rounded-xl overflow-hidden opacity-20 rotate-[-6deg] shadow-lg">
            <img src={sanityImageUrl('image-85d73f4797b625e01e2a66df43cea27625e0ad72-800x600-jpg', 300)} alt="" class="w-full h-full object-cover blur-[1px]" loading="lazy" />
          </div>
          <div class="hidden lg:block absolute -right-4 top-16 w-28 h-40 rounded-xl overflow-hidden opacity-20 rotate-[4deg] shadow-lg">
            <img src={sanityImageUrl('image-edc2f2636d0dc93ab0405ea0bd67f8b6f4f1f308-800x450-jpg', 300)} alt="" class="w-full h-full object-cover blur-[1px]" loading="lazy" />
          </div>
          <div class="hidden lg:block absolute -left-2 bottom-12 w-24 h-36 rounded-xl overflow-hidden opacity-15 rotate-[3deg] shadow-lg">
            <img src={sanityImageUrl('image-c61680ea417e75d3fcb13f4a245138209cac4eef-800x600-jpg', 300)} alt="" class="w-full h-full object-cover blur-[1px]" loading="lazy" />
          </div>
          <div class="hidden lg:block absolute -right-2 bottom-8 w-30 h-40 rounded-xl overflow-hidden opacity-15 rotate-[-5deg] shadow-lg">
            <img src={sanityImageUrl('image-2152c5a90b06cad5a62b5f582b0d836a8b6c54e3-598x800-jpg', 300)} alt="" class="w-full h-full object-cover blur-[1px]" loading="lazy" />
          </div>
        </>
      )}
      <div class="text-center relative z-10">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900">{missionHeading}</h2>
      <p class="mt-4 text-lg text-gray-600 max-w-3xl mx-auto leading-relaxed">
        {missionBody}
      </p>
      <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8">
        {missionCards.map((card) => (
          <div class="p-6 bg-white rounded-card shadow-card border-t-2 border-transparent hover:border-primary-500 hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
            <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-primary-100 flex items-center justify-center">
              <span class="text-2xl">{card.icon}</span>
            </div>
            <h3 class="text-lg font-semibold text-gray-900">{card.title}</h3>
            <p class="mt-2 text-sm text-gray-600">{card.description}</p>
          </div>
        ))}
      </div>
    </div>
    </div>
  </Section>

  <!-- Featured Story -->
  {testimonials.length > 0 && (
    <Section background="white" padding="md">
      <div class="max-w-3xl mx-auto">
        <a href="/stories/mama-rose-grandchildren" class="group block p-6 bg-gradient-to-r from-primary-50 to-accent-50 rounded-2xl border border-primary-100 hover:shadow-lg transition-all duration-300">
          <div class="flex items-center gap-2 mb-2">
            <span class="px-2 py-0.5 text-[10px] font-semibold uppercase bg-purple-100 text-purple-700 rounded-full">Featured Story</span>
          </div>
          <h3 class="text-xl font-heading font-bold text-gray-900 group-hover:text-primary-700 transition-colors">Mama Patience: From Selling Her Last Cooking Pots to Running a Business</h3>
          <p class="mt-2 text-sm text-gray-600 leading-relaxed">When her husband died, Patience lost everything. She was selling her cooking pots one by one to feed her four children. Today, thanks to a $400 investment over 12 months, she runs a food business at the Bamenda market.</p>
          <span class="mt-3 inline-block text-sm font-medium text-primary-600">Read her full story →</span>
        </a>
      </div>
    </Section>
  )}

  <!-- Testimonials Section -->
  <Section background="white" padding="lg">
    <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900 text-center">Stories of Impact</h2>
    <p class="mt-4 text-gray-600 text-center max-w-2xl mx-auto">Real stories from the people we serve.</p>
    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map((t) => (
        <div class="p-6 bg-gray-50 rounded-card shadow-card">
          <p class="text-gray-700 italic leading-relaxed">"{t.quote}"</p>
          <div class="mt-4 pt-4 border-t border-gray-200">
            <p class="text-sm font-semibold text-gray-900">{t.name}</p>
            <p class="text-xs text-gray-500">{t.program}{t.location ? ` \u2022 ${t.location}` : ''}</p>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <!-- CTA Section -->
  <Section background="dark" padding="lg" class="!bg-gray-900 !bg-none">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-heading font-bold">{ctaHeading}</h2>
      <p class="mt-4 text-lg text-white/80">
        {ctaBody}
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/donate"
          class="inline-flex items-center px-6 py-3 text-base font-semibold text-primary-800 bg-white rounded-lg hover:bg-gray-100 transition-colors"
          data-umami-event="cta-donate"
        >
          Donate Now
        </a>
        <a
          href="/get-involved"
          class="inline-flex items-center px-6 py-3 text-base font-semibold text-white border-2 border-white/30 rounded-lg hover:bg-white/10 transition-colors"
        >
          Volunteer With Us
        </a>
      </div>
    </div>
  </Section>

  <!-- Newsletter Section -->
  <Section background="gray" padding="lg">
    <div class="text-center">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-gray-900">Stay Connected</h2>
      <p class="mt-2 text-gray-600 max-w-lg mx-auto">Get updates on our impact, stories, and upcoming projects delivered to your inbox.</p>
      <div class="mt-6">
        <NewsletterSignup client:visible />
      </div>
    </div>
  </Section>
</PageLayout>
