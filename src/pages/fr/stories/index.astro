---
import PageLayout from '../../../layouts/PageLayout.astro';
import PageHero from '../../../components/layout/PageHero.astro';
import Section from '../../../components/layout/Section.astro';
import { createClient } from '@sanity/client';

let posts: any[] = [];
try {
  const projectId = import.meta.env.SANITY_PROJECT_ID || 'rj2m21gk';
  const dataset = import.meta.env.SANITY_DATASET || 'production';
  const client = createClient({ projectId, dataset, apiVersion: '2026-03-28', useCdn: true });
  posts = await client.fetch('*[_type == "blogPost"] | order(publishedAt desc) { _id, title, titleFr, slug, excerpt, excerptFr, publishedAt, category }');
} catch {}
---

<PageLayout title="Témoignages & Actualités" description="Lisez des histoires d'impact, des mises à jour de programmes et des annonces d'Apoti Development Association.">
  <PageHero title="Témoignages & Actualités" subtitle="Nouvelles, histoires d'impact et annonces de nos programmes." badge="Notre Blog" compact />

  <Section background="white" padding="lg">
    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <a href={`/fr/stories/${post.slug.current}`} class="group">
            <article class="p-6 bg-gray-50 rounded-card shadow-card hover:shadow-card-hover transition-shadow">
              <span class="text-xs font-medium text-primary-600 uppercase">{post.category || 'actualité'}</span>
              <h2 class="mt-2 text-lg font-semibold text-gray-900 group-hover:text-primary-700 transition-colors">{post.titleFr || post.title}</h2>
              <p class="mt-2 text-sm text-gray-600 line-clamp-3">{post.excerptFr || post.excerpt}</p>
              {post.publishedAt && <p class="mt-3 text-xs text-gray-400">{new Date(post.publishedAt).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}</p>}
            </article>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-12">
        <span class="text-5xl">✍️</span>
        <h2 class="mt-4 text-xl font-semibold text-gray-900">Histoires à Venir</h2>
        <p class="mt-2 text-gray-600">Nous travaillons à partager plus d'histoires d'impact. Revenez bientôt !</p>
      </div>
    )}
  </Section>
</PageLayout>
