---
import PageLayout from '../../../layouts/PageLayout.astro';
import PageHero from '../../../components/layout/PageHero.astro';
import Section from '../../../components/layout/Section.astro';
import { sanityImageUrl } from '../../../lib/sanity';
import { createClient } from '@sanity/client';

let posts: any[] = [];
let galleryPhotos: any[] = [];
try {
  const projectId = import.meta.env.SANITY_PROJECT_ID || 'rj2m21gk';
  const dataset = import.meta.env.SANITY_DATASET || 'production';
  const client = createClient({ projectId, dataset, apiVersion: '2026-03-28', useCdn: true });
  posts = await client.fetch('*[_type == "blogPost"] | order(publishedAt desc) { _id, title, titleFr, slug, excerpt, excerptFr, publishedAt, category, personPhoto { asset { _ref }, alt } }');
  galleryPhotos = await client.fetch('*[_type == "galleryImage" && defined(photo)] | order(year desc) [0...4] { _id, title, photo { asset { _ref }, alt } }');
} catch {}

const categories = ['all', 'story', 'update', 'announcement'];
const categoryLabels: Record<string, string> = {
  all: 'Tous',
  story: 'Histoires',
  update: 'Actualités',
  announcement: 'Annonces',
};
---

<PageLayout title="Témoignages & Actualités" description="Lisez des histoires d'impact, des mises à jour de programmes et des annonces d'Apoti Development Association.">
  <PageHero title="Témoignages & Actualités" subtitle="Nouvelles, histoires d'impact et annonces de nos programmes." badge="Notre Blog" compact />

  <Section background="white" padding="lg">
    {posts.length > 0 ? (
      <div>
        <!-- Category Filters -->
        <div class="flex flex-wrap gap-2 mb-8" id="story-filters">
          {categories.map((cat) => (
            <button
              data-filter={cat}
              class:list={["px-4 py-2 text-sm font-medium rounded-full transition-colors", cat === 'all' ? "bg-primary-600 text-white" : "bg-gray-100 text-gray-700 hover:bg-gray-200"]}
            >
              {categoryLabels[cat]} ({cat === 'all' ? posts.length : posts.filter(p => p.category === cat).length})
            </button>
          ))}
        </div>

        <!-- Posts Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="stories-grid">
          {posts.map((post) => (
            <a href={`/fr/stories/${post.slug.current}`} class="group story-card" data-category={post.category || 'update'}>
              <article class="h-full flex flex-col p-0 bg-gray-50 rounded-xl border border-gray-100 hover:border-primary-200 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 overflow-hidden">
                {post.personPhoto?.asset?._ref && (
                  <div class="h-40 overflow-hidden">
                    <img src={sanityImageUrl(post.personPhoto.asset._ref, 400)} alt={post.personPhoto?.alt || (post.titleFr || post.title)} class="w-full h-full object-cover" loading="lazy" />
                  </div>
                )}
                <div class="p-5 flex flex-col flex-1">
                  <div class="flex items-center gap-2 mb-3">
                    <span class:list={["px-2 py-0.5 text-[10px] font-semibold uppercase rounded-full", post.category === 'story' ? 'bg-purple-100 text-purple-700' : post.category === 'announcement' ? 'bg-blue-100 text-blue-700' : 'bg-green-100 text-green-700']}>
                      {post.category === 'story' ? 'histoire' : post.category === 'announcement' ? 'annonce' : 'actualité'}
                    </span>
                    {post.publishedAt && (
                      <time class="text-xs text-gray-400">{new Date(post.publishedAt).toLocaleDateString('fr-FR', { year: 'numeric', month: 'short' })}</time>
                    )}
                  </div>
                  <h2 class="text-lg font-semibold text-gray-900 group-hover:text-primary-700 transition-colors leading-tight">{post.titleFr || post.title}</h2>
                  <p class="mt-3 text-sm text-gray-600 line-clamp-3 leading-relaxed flex-1">{post.excerptFr || post.excerpt}</p>
                  <span class="mt-4 inline-block text-sm font-medium text-primary-600 group-hover:text-primary-700">Lire la suite →</span>
                </div>
              </article>
            </a>
          ))}
        </div>
      </div>
    ) : (
      <div class="text-center py-12">
        <span class="text-5xl">✍️</span>
        <h2 class="mt-4 text-xl font-semibold text-gray-900">Histoires à Venir</h2>
        <p class="mt-2 text-gray-600">Nous travaillons à partager plus d'histoires d'impact. Revenez bientôt !</p>
      </div>
    )}
  </Section>

  <Section background="gray" padding="md">
    <div class="text-center">
      <h3 class="text-lg font-heading font-semibold text-gray-900 mb-4">📷 De Notre Galerie</h3>
      {galleryPhotos.length > 0 && (
        <div class="flex justify-center gap-3 mb-4">
          {galleryPhotos.map((img) => (
            <a href="/fr/gallery" class="block w-20 h-20 rounded-lg overflow-hidden hover:opacity-80 transition-opacity">
              <img src={sanityImageUrl(img.photo.asset._ref, 160)} alt={img.photo?.alt || img.title} class="w-full h-full object-cover" loading="lazy" />
            </a>
          ))}
        </div>
      )}
      <a href="/fr/gallery" class="inline-flex items-center gap-2 text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors">
        Voir la galerie complète →
      </a>
    </div>
  </Section>
</PageLayout>

<script>
  const buttons = document.querySelectorAll('#story-filters button');
  const cards = document.querySelectorAll('.story-card');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');

      buttons.forEach(b => {
        b.classList.remove('bg-primary-600', 'text-white');
        b.classList.add('bg-gray-100', 'text-gray-700');
      });
      btn.classList.remove('bg-gray-100', 'text-gray-700');
      btn.classList.add('bg-primary-600', 'text-white');

      cards.forEach(card => {
        if (filter === 'all' || card.getAttribute('data-category') === filter) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
