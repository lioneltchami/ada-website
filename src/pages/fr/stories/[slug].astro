---
import PageLayout from '../../../layouts/PageLayout.astro';
import Section from '../../../components/layout/Section.astro';
import PortableTextRenderer from '../../../components/PortableTextRenderer';
import { sanityImageUrl } from '../../../lib/sanity';
import { createClient } from '@sanity/client';

export async function getStaticPaths() {
  let posts: any[] = [];
  try {
    const projectId = import.meta.env.SANITY_PROJECT_ID || 'rj2m21gk';
    const dataset = import.meta.env.SANITY_DATASET || 'production';
    const client = createClient({ projectId, dataset, apiVersion: '2026-03-28', useCdn: true });
    posts = await client.fetch('*[_type == "blogPost"] | order(publishedAt desc) { _id, title, titleFr, slug, excerpt, excerptFr, body, bodyFr, publishedAt, category, personPhoto { asset { _ref }, alt } }');
  } catch {}
  return posts.map((post) => ({ params: { slug: post.slug.current }, props: { post } }));
}

const { post } = Astro.props;
const title = post.titleFr || post.title;
const excerpt = post.excerptFr || post.excerpt;
const body = post.bodyFr || post.body;
const photoUrl = post.personPhoto?.asset?._ref ? sanityImageUrl(post.personPhoto.asset._ref, 400) : '';
---

<PageLayout title={title} description={excerpt}>
  <article>
    <section class="bg-gradient-to-br from-primary-800 via-primary-700 to-primary-900 text-white py-16 md:py-20">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol class="flex items-center gap-1.5 text-sm text-white/70">
            <li><a href="/fr" class="hover:text-white transition-colors">Accueil</a></li>
            <li class="text-white/40">/</li>
            <li><a href="/fr/stories" class="hover:text-white transition-colors">Témoignages</a></li>
            <li class="text-white/40">/</li>
            <li class="text-white/90 truncate max-w-[200px]">{title}</li>
          </ol>
        </nav>
        <div class="flex items-center gap-3 mb-4">
          <span class="px-3 py-1 text-xs font-medium uppercase bg-white/10 text-white/90 rounded-full border border-white/20">{post.category === 'story' ? 'histoire' : post.category === 'update' ? 'actualité' : 'annonce'}</span>
          {post.publishedAt && <time class="text-sm text-white/60">{new Date(post.publishedAt).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}</time>}
        </div>
        <h1 class="text-3xl md:text-4xl font-heading font-bold leading-tight">{title}</h1>
        <p class="mt-4 text-lg text-white/80 leading-relaxed">{excerpt}</p>
      </div>
    </section>

    <Section background="white" padding="lg">
      <div class="max-w-3xl mx-auto">
        {photoUrl && (
          <div class="mb-8 flex justify-center">
            <img src={photoUrl} alt={post.personPhoto?.alt || title} class="w-48 h-48 rounded-2xl object-cover shadow-lg" loading="eager" />
          </div>
        )}
        <div class="prose prose-gray prose-lg">
        {Array.isArray(body) ? (
          <PortableTextRenderer client:load value={body} />
        ) : (
          <div>
            {(body || '').split('\n\n').filter(Boolean).map((para) => (
              <p class="text-gray-600 leading-relaxed mb-4">{para.trim()}</p>
            ))}
          </div>
        )}
        </div>
      </div>
    </Section>

    <!-- Share -->
    <Section background="white" padding="sm">
      <div class="max-w-3xl mx-auto flex items-center justify-center gap-3">
        <span class="text-sm text-gray-500">Partager :</span>
        <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=https://apotidev.org/fr/stories/${post.slug.current}`} target="_blank" rel="noopener" class="px-3 py-1.5 text-xs font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">X</a>
        <a href={`https://www.facebook.com/sharer/sharer.php?u=https://apotidev.org/fr/stories/${post.slug.current}`} target="_blank" rel="noopener" class="px-3 py-1.5 text-xs font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">Facebook</a>
        <a href={`https://wa.me/?text=${encodeURIComponent(title + ' https://apotidev.org/fr/stories/' + post.slug.current)}`} target="_blank" rel="noopener" class="px-3 py-1.5 text-xs font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">WhatsApp</a>
      </div>
    </Section>

    <Section background="gray" padding="md">
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-gray-600">Inspiré(e) par cette histoire ?</p>
        <div class="mt-4 flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href="/fr/donate" class="px-6 py-3 text-sm font-semibold text-white bg-secondary-500 rounded-lg hover:bg-secondary-600 transition-colors">Soutenir Notre Mission</a>
          <a href="/fr/stories" class="px-6 py-3 text-sm font-medium text-primary-700 border border-primary-200 rounded-lg hover:bg-primary-50 transition-colors">Lire Plus d'Histoires</a>
        </div>
      </div>
    </Section>
  </article>
</PageLayout>
