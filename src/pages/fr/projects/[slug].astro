---
import PageLayout from "../../../layouts/PageLayout.astro";
import Section from "../../../components/layout/Section.astro";
import { getProjects, type SanityProject } from '../../../lib/sanity';
import { projects as fallbackProjects } from '../../../data/projects';

export async function getStaticPaths() {
  let projectData;
  try {
    const sanityProjects = await getProjects();
    if (sanityProjects?.length) {
      projectData = sanityProjects.map((p: SanityProject) => ({
        slug: p.slug.current, title: p.title, location: p.location, status: p.status,
        description: p.description, beneficiaries: p.beneficiaries, goal: p.goalAmount, raised: p.raisedAmount,
      }));
    } else { projectData = fallbackProjects; }
  } catch { projectData = fallbackProjects; }

  return projectData.map((project) => ({ params: { slug: project.slug }, props: { project } }));
}

const { project } = Astro.props;
const progress = Math.min(100, (project.raised / project.goal) * 100);
const costPerBeneficiary = project.beneficiaries > 0 ? Math.round(project.raised / project.beneficiaries) : 0;

const paragraphs = project.description.split(/[.;]\s*(?=[A-Z(])/).filter(Boolean).reduce((acc: string[][], sentence: string, i: number) => {
  const paraIndex = Math.floor(i / 3);
  if (!acc[paraIndex]) acc[paraIndex] = [];
  acc[paraIndex].push(sentence.trim());
  return acc;
}, [] as string[][]).map((sentences: string[]) => sentences.join('. ') + (sentences[sentences.length - 1].endsWith('.') ? '' : '.'));
---

<PageLayout title={project.title} description={project.description.slice(0, 160)}>
  <!-- Hero -->
  <section class="relative py-16 md:py-24 bg-gradient-to-br from-primary-800 via-primary-700 to-primary-900 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/fr/projects" class="inline-flex items-center text-sm text-white/70 hover:text-white mb-6 transition-colors">
        ← Retour aux Projets
      </a>
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <span class:list={["px-3 py-1 text-xs font-semibold rounded-full", project.status === "active" ? "bg-green-400/20 text-green-200 border border-green-400/30" : project.status === "completed" ? "bg-gray-400/20 text-gray-200 border border-gray-400/30" : "bg-yellow-400/20 text-yellow-200 border border-yellow-400/30"]}>
          {project.status === "active" ? "● Actif" : project.status === "completed" ? "✓ Terminé" : "⏸ En pause"}
        </span>
        <span class="text-sm text-white/70">📍 {project.location}</span>
        <span class="text-sm text-white/70">👥 {project.beneficiaries} bénéficiaires</span>
      </div>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold leading-tight">{project.title}</h1>
      <p class="mt-4 text-lg text-white/80 max-w-2xl">Au service des communautés vulnérables à {project.location}, Cameroun</p>
    </div>
  </section>

  <!-- Quick Stats Bar -->
  <div class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
        <div>
          <p class="text-xl font-bold text-primary-700">{project.beneficiaries}</p>
          <p class="text-xs text-gray-500">Personnes Aidées</p>
        </div>
        <div>
          <p class="text-xl font-bold text-primary-700">${project.raised.toLocaleString()}</p>
          <p class="text-xs text-gray-500">Collecté à ce jour</p>
        </div>
        <div>
          <p class="text-xl font-bold text-primary-700">{Math.round(progress)}%</p>
          <p class="text-xs text-gray-500">Financé</p>
        </div>
        <div>
          <p class="text-xl font-bold text-primary-700">${costPerBeneficiary}</p>
          <p class="text-xs text-gray-500">Coût par Personne</p>
        </div>
      </div>
    </div>
  </div>

  <Section background="white" padding="lg">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Main Content -->
      <div class="lg:col-span-2">
        <div class="space-y-6">
          <h2 class="text-2xl font-heading font-bold text-gray-900">À Propos de ce Projet</h2>
          <div class="prose prose-gray max-w-none space-y-4">
            {paragraphs.map((para) => (
              <p class="text-gray-600 leading-relaxed">{para}</p>
            ))}
          </div>
        </div>

        <!-- Impact Metrics -->
        <div class="mt-10">
          <h3 class="text-lg font-heading font-semibold text-gray-900">Impact en un Coup d'Œil</h3>
          <div class="mt-4 grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="p-4 bg-primary-50 rounded-xl border border-primary-100 text-center">
              <p class="text-2xl font-bold text-primary-700">{project.beneficiaries}</p>
              <p class="text-xs text-gray-600">Bénéficiaires Directs</p>
            </div>
            <div class="p-4 bg-primary-50 rounded-xl border border-primary-100 text-center">
              <p class="text-2xl font-bold text-primary-700">{project.location}</p>
              <p class="text-xs text-gray-600">Localisation</p>
            </div>
            <div class="p-4 bg-primary-50 rounded-xl border border-primary-100 text-center">
              <p class="text-2xl font-bold text-primary-700">${costPerBeneficiary}</p>
              <p class="text-xs text-gray-600">Par Bénéficiaire</p>
            </div>
          </div>
        </div>

        <!-- Sustainability -->
        <div class="mt-10 p-6 bg-gradient-to-r from-primary-50 to-accent-50 rounded-2xl border border-primary-100">
          <h3 class="text-lg font-heading font-semibold text-gray-900">♻️ Durabilité</h3>
          <p class="mt-2 text-sm text-gray-700 leading-relaxed">
            Ce programme est conçu pour survivre au financement externe. Les bénéficiaires acquièrent des compétences et des réseaux qui génèrent des revenus de manière indépendante. Les diplômés deviennent des mentors pour les futures cohortes, créant un cycle autonome d'autonomisation. Lorsque le financement prend fin, les compétences, les structures communautaires et le leadership local demeurent.
          </p>
        </div>

        <!-- Gender Impact -->
        <div class="mt-6 p-6 bg-accent-50 rounded-2xl border border-accent-100">
          <h3 class="text-lg font-heading font-semibold text-gray-900">🎯 Égalité des Genres</h3>
          <p class="mt-2 text-sm text-gray-700 leading-relaxed">
            85% des bénéficiaires de ce projet sont des femmes et des filles. Notre approche fait directement progresser l'égalité des genres en restaurant l'autonomie économique, en offrant l'accès à l'éducation et en construisant des voies vers l'indépendance financière pour les plus marginalisées.
          </p>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Fundraising Card -->
        <div class="p-6 bg-gray-50 rounded-2xl border border-gray-200 sticky top-24">
          <h3 class="text-lg font-semibold text-gray-900">Progression de la Collecte</h3>
          <div class="mt-4">
            <div class="flex justify-between text-sm mb-2">
              <span class="font-bold text-gray-900">${project.raised.toLocaleString()}</span>
              <span class="text-gray-500">sur ${project.goal.toLocaleString()}</span>
            </div>
            <div class="w-full h-4 bg-gray-200 rounded-full overflow-hidden" role="progressbar" aria-valuenow={Math.round(progress)} aria-valuemin="0" aria-valuemax="100" aria-label="Progression de la collecte">
              <div class="h-full bg-gradient-to-r from-primary-500 to-primary-400 rounded-full transition-all" style={`width: ${progress}%`}></div>
            </div>
            <p class="mt-2 text-sm text-gray-600">{Math.round(progress)}% financé</p>
            <p class="mt-1 text-xs text-gray-500">${(project.goal - project.raised).toLocaleString()} encore nécessaires</p>
          </div>

          <a href={`/fr/donate?project=${project.slug}`} class="mt-6 block w-full text-center px-4 py-3.5 text-base font-semibold text-white bg-secondary-500 rounded-xl hover:bg-secondary-600 transition-colors shadow-md shadow-secondary-500/20">
            Soutenir ce Projet
          </a>

          <div class="mt-4 text-center">
            <p class="text-xs text-gray-500">🔒 Sécurisé · 80% aux programmes · Reçu par email</p>
          </div>
        </div>

        <!-- Quick Facts -->
        <div class="p-6 bg-white rounded-2xl border border-gray-200">
          <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider">Faits Rapides</h3>
          <dl class="mt-4 space-y-3">
            <div class="flex justify-between">
              <dt class="text-xs text-gray-500">Statut</dt>
              <dd class="text-xs font-medium text-gray-900">{project.status === "active" ? "Actif" : project.status === "completed" ? "Terminé" : "En pause"}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-xs text-gray-500">Localisation</dt>
              <dd class="text-xs font-medium text-gray-900">{project.location}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-xs text-gray-500">Bénéficiaires</dt>
              <dd class="text-xs font-medium text-gray-900">{project.beneficiaries} personnes</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-xs text-gray-500">Coût par personne</dt>
              <dd class="text-xs font-medium text-gray-900">${costPerBeneficiary}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-xs text-gray-500">Accent genre</dt>
              <dd class="text-xs font-medium text-gray-900">85% femmes & filles</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-xs text-gray-500">Frais admin</dt>
              <dd class="text-xs font-medium text-gray-900">5%</dd>
            </div>
          </dl>
        </div>

        <!-- Share -->
        <div class="p-6 bg-white rounded-2xl border border-gray-200">
          <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider">Partager ce Projet</h3>
          <div class="mt-3 flex gap-2">
            <a href={`https://twitter.com/intent/tweet?text=Soutenez ${encodeURIComponent(project.title)} au Cameroun&url=https://apotidev.org/fr/projects/${project.slug}`} target="_blank" rel="noopener" class="flex-1 text-center px-3 py-2 text-xs font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">X</a>
            <a href={`https://www.facebook.com/sharer/sharer.php?u=https://apotidev.org/fr/projects/${project.slug}`} target="_blank" rel="noopener" class="flex-1 text-center px-3 py-2 text-xs font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">Facebook</a>
            <a href={`https://wa.me/?text=Soutenez ${encodeURIComponent(project.title)} https://apotidev.org/fr/projects/${project.slug}`} target="_blank" rel="noopener" class="flex-1 text-center px-3 py-2 text-xs font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">WhatsApp</a>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- Other Projects -->
  <Section background="gray" padding="md">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-xl font-heading font-bold text-gray-900">Découvrir Plus de Projets</h2>
      <p class="mt-2 text-sm text-gray-600">Chaque projet aborde une dimension différente de la vulnérabilité au Cameroun.</p>
      <div class="mt-4 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/fr/projects" class="px-5 py-2.5 text-sm font-medium text-primary-700 border border-primary-200 rounded-lg hover:bg-primary-50 transition-colors">Voir Tous les Projets</a>
        <a href="/fr/transparency" class="px-5 py-2.5 text-sm font-medium text-gray-600 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors">Voir Nos Données d'Impact</a>
      </div>
    </div>
  </Section>
</PageLayout>
