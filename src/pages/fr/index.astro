---
import PageLayout from '../../layouts/PageLayout.astro';
import Section from '../../components/layout/Section.astro';
import NewsletterSignup from '../../components/islands/NewsletterSignup';
import { getImpactMetrics, getHomePage, getTestimonials, type SanityImpactMetric, type SanityHomePage } from '../../lib/sanity';
import { t } from '../../i18n';

const i18n = t('fr');

let stats = [
  { value: '200+', label: i18n.stats.livesImpacted },
  { value: '5', label: i18n.stats.communitiesServed },
  { value: '15+', label: i18n.stats.widowsSupported },
  { value: '5', label: i18n.stats.yearsOfService },
];

try {
  const metrics = await getImpactMetrics();
  if (metrics?.length) {
    const labelMap: Record<string, string> = {
      'Lives Impacted': i18n.stats.livesImpacted,
      'Communities Served': i18n.stats.communitiesServed,
      'Widows Supported': i18n.stats.widowsSupported,
      'Years of Service': i18n.stats.yearsOfService,
    };
    stats = metrics.map((m: SanityImpactMetric) => ({
      value: `${m.value}${m.suffix || ''}`,
      label: labelMap[m.label] || m.label,
    }));
  }
} catch {}

interface Testimonial { name: string; quote: string; location: string; program: string; }
const fallbackTestimonials: Testimonial[] = [
  { name: 'Amina N.', quote: "Après le décès de mon mari, je ne savais pas comment nourrir mes enfants. ADA m'a fourni des colis alimentaires et m'a inscrite à une formation en couture. Aujourd'hui je gère ma propre boutique.", location: 'Bamenda', program: 'Programme Veuves' },
  { name: 'Marie F.', quote: "ADA a payé mes frais de scolarité quand ma grand-mère ne pouvait pas. Ils m'ont donné des livres, un uniforme et un mentor. Je veux devenir infirmière.", location: 'Douala', program: 'Éducation des Orphelins' },
  { name: 'Esther K.', quote: "Le programme de formation m'a appris la coiffure. ADA m'a même aidée à obtenir mes premiers outils. Maintenant j'ai des clients réguliers.", location: 'Yaoundé', program: 'Autonomisation des Femmes' },
];
let testimonials: Testimonial[] = fallbackTestimonials;
try {
  const data = await getTestimonials();
  if (data?.length) {
    testimonials = data.map((t: any) => ({ name: t.name, quote: t.quote, location: t.location || '', program: t.program || '' }));
  }
} catch {}
---

<PageLayout title="Autonomiser les Communautés au Cameroun" description="Association caritative chrétienne soutenant les veuves, orphelins et jeunes femmes au Cameroun depuis 2021.">
  <!-- Hero -->
  <section class="relative overflow-hidden py-24 md:py-32 bg-gradient-to-br from-primary-800 via-primary-700 to-primary-900 text-white">
    <div class="absolute inset-0 opacity-10" aria-hidden="true">
      <div class="absolute top-20 left-10 w-72 h-72 bg-primary-300 rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-10 w-96 h-96 bg-accent-300 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block px-4 py-1.5 mb-6 text-sm font-medium bg-white/10 backdrop-blur-sm rounded-full border border-white/20">{i18n.hero.badge}</span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold leading-tight">{i18n.hero.headline}</h1>
      <p class="mt-6 text-lg md:text-xl text-white/80 max-w-2xl mx-auto leading-relaxed">{i18n.hero.subtitle}</p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/fr/donate" class="inline-flex items-center px-6 py-3 text-base font-semibold text-primary-900 bg-white rounded-lg hover:bg-gray-100 transition-colors shadow-lg">{i18n.hero.cta}</a>
        <a href="/fr/projects" class="inline-flex items-center px-6 py-3 text-base font-semibold text-white border-2 border-white/30 rounded-lg hover:bg-white/10 transition-colors">{i18n.hero.ctaSecondary}</a>
      </div>
      <p class="mt-4 text-sm text-white/60">{i18n.hero.socialProof}</p>
    </div>
  </section>

  <!-- Stats -->
  <Section background="white" padding="md">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      {stats.map((stat, i) => (
        <div class="stat-animate" style={`animation-delay: ${i * 150}ms`}>
          <p class="text-3xl md:text-4xl font-bold text-primary-700">{stat.value}</p>
          <p class="mt-1 text-sm text-gray-600">{stat.label}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- Campaign -->
  <Section background="white" padding="sm">
    <div class="max-w-2xl mx-auto">
      <div class="p-6 bg-gradient-to-r from-primary-50 to-accent-50 rounded-2xl border border-primary-100">
        <div class="flex items-center justify-between mb-2">
          <h3 class="text-sm font-semibold text-gray-900">{i18n.campaign.title}</h3>
          <span class="text-xs font-medium text-red-700 bg-red-50 px-2 py-0.5 rounded-full">{i18n.campaign.deadline}</span>
        </div>
        <p class="text-xs text-gray-600 mb-3">{i18n.campaign.description}</p>
        <div class="w-full h-3 bg-gray-200 rounded-full overflow-hidden" role="progressbar" aria-valuenow="44" aria-valuemin="0" aria-valuemax="100">
          <div class="h-full bg-gradient-to-r from-primary-500 to-primary-400 rounded-full" style="width: 44%"></div>
        </div>
        <div class="flex items-center justify-between mt-2">
          <span class="text-sm font-bold text-primary-700">$2,200 {i18n.campaign.raised}</span>
          <span class="text-xs text-gray-500">{i18n.campaign.goal}: $5,000 · 47 {i18n.campaign.donors}</span>
        </div>
        <a href="/fr/donate?project=education-drive" class="mt-4 block w-full text-center px-4 py-2.5 text-sm font-semibold text-white bg-secondary-500 rounded-lg hover:bg-secondary-600 transition-colors">{i18n.campaign.cta}</a>
      </div>
    </div>
  </Section>

  <!-- Mission -->
  <Section background="gray" padding="lg">
    <div class="max-w-7xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900">{i18n.mission.heading}</h2>
      <p class="mt-4 text-lg text-gray-600 max-w-3xl mx-auto leading-relaxed">{i18n.mission.body}</p>
    </div>
  </Section>

  <!-- Testimonials -->
  <Section background="white" padding="lg">
    <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900 text-center">{i18n.testimonials.heading}</h2>
    <p class="mt-4 text-gray-600 text-center max-w-2xl mx-auto">{i18n.testimonials.subtitle}</p>
    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map((te) => (
        <div class="p-6 bg-gray-50 rounded-card shadow-card">
          <p class="text-gray-700 italic leading-relaxed">"{te.quote}"</p>
          <div class="mt-4 pt-4 border-t border-gray-200">
            <p class="text-sm font-semibold text-gray-900">{te.name}</p>
            <p class="text-xs text-gray-500">{te.program}{te.location ? ` • ${te.location}` : ''}</p>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <!-- Founder -->
  <Section background="gray" padding="md">
    <div class="max-w-3xl mx-auto text-center">
      <blockquote class="text-lg md:text-xl text-gray-700 italic leading-relaxed">&ldquo;{i18n.founder.quote}&rdquo;</blockquote>
      <div class="mt-4">
        <p class="text-sm font-semibold text-gray-900">{i18n.founder.name}</p>
        <p class="text-xs text-gray-500">{i18n.founder.role}</p>
      </div>
    </div>
  </Section>

  <!-- CTA -->
  <Section background="dark" padding="lg" class="!bg-gray-900 !bg-none">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-heading font-bold">{i18n.cta.heading}</h2>
      <p class="mt-4 text-lg text-white/80">{i18n.cta.body}</p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/fr/donate" class="inline-flex items-center px-6 py-3 text-base font-semibold text-primary-800 bg-white rounded-lg hover:bg-gray-100 transition-colors">{i18n.cta.donate}</a>
        <a href="/fr/get-involved" class="inline-flex items-center px-6 py-3 text-base font-semibold text-white border-2 border-white/30 rounded-lg hover:bg-white/10 transition-colors">{i18n.cta.volunteer}</a>
      </div>
    </div>
  </Section>

  <!-- Newsletter -->
  <Section background="gray" padding="lg">
    <div class="text-center">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-gray-900">{i18n.newsletter.heading}</h2>
      <p class="mt-2 text-gray-600 max-w-lg mx-auto">{i18n.newsletter.subtitle}</p>
      <div class="mt-6">
        <NewsletterSignup client:visible />
      </div>
    </div>
  </Section>
</PageLayout>
