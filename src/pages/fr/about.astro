---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/layout/PageHero.astro';
import Section from '../../components/layout/Section.astro';
import { getAboutPage, type SanityAboutPage, sanityImageUrl } from '../../lib/sanity';
import { createClient } from '@sanity/client';

let missionStatement = "Faire briller la lumière de Jésus-Christ en autonomisant les communautés vulnérables du Cameroun à travers la distribution alimentaire, l'éducation, la formation professionnelle et les soins de santé.";
let storyParagraphs = [
  "Fondée en 2021, Apoti Development Association est née d'une conviction profonde que la foi doit s'exprimer par l'action. Au cœur du Cameroun, où les veuves, les orphelins et les jeunes femmes font face à des défis quotidiens de pauvreté et de marginalisation, nous avons vu une opportunité de faire une différence tangible.",
  "Le Pasteur Emmanuel Tchami, témoin des luttes des veuves de sa communauté qui avaient tout perdu — leur mari, leurs revenus, leur dignité — s'est senti appelé à agir. Il a rassemblé un petit groupe de croyants engagés et ensemble, ils ont livré leurs premiers colis alimentaires à trois veuves à Bamenda.",
  "Ce qui a commencé comme un simple acte de compassion est devenu une organisation communautaire servant 5 communautés à travers le Cameroun, touchant plus de 200 vies à travers six programmes ciblés. Chaque programme est conçu non seulement pour apporter un soulagement, mais pour construire une autonomie durable.",
];
let coreValues = [
  { icon: '❤️', title: 'Foi et Amour', desc: 'Enracinés dans la foi chrétienne, nous servons avec un amour inconditionnel.' },
  { icon: '🙏', title: 'Dignité et Respect', desc: "Chaque personne est traitée avec la dignité qu'elle mérite." },
  { icon: '🌱', title: 'Autonomisation', desc: 'Nous équipons les gens de compétences pour construire leur propre avenir.' },
  { icon: '🔍', title: 'Transparence', desc: 'Nous sommes responsables envers nos donateurs et communautés.' },
  { icon: '🤝', title: 'Partenariat Communautaire', desc: 'Nous travaillons aux côtés des leaders locaux.' },
  { icon: '♻️', title: 'Impact Durable', desc: 'Nos programmes créent un changement à long terme, pas un soulagement temporaire.' },
];
let programs = [
  { icon: '🍚', title: 'Distribution Alimentaire', desc: 'Colis alimentaires réguliers pour les veuves et familles.', slug: 'widow-support' },
  { icon: '✂️', title: 'Formation Professionnelle', desc: 'Couture, coiffure et artisanat pour les jeunes femmes.', slug: 'women-empowerment' },
  { icon: '🏥', title: 'Visites Hospitalières', desc: 'Soutien médical et visites aux membres de la communauté.', slug: 'emergency-relief' },
  { icon: '📚', title: 'Soutien Scolaire', desc: 'Fournitures, uniformes et frais de scolarité pour les orphelins.', slug: 'education-orphans' },
  { icon: '💧', title: 'Eau Potable', desc: "Accès à l'eau potable pour les communautés défavorisées.", slug: 'widow-support' },
  { icon: '🧹', title: 'Nettoyage Communautaire', desc: "Gestion environnementale à travers des campagnes de nettoyage et plantation d'arbres.", slug: 'women-empowerment' },
];
let timeline = [
  { year: '2021', event: 'Fondée au Cameroun — premiers colis alimentaires livrés à 3 veuves à Bamenda' },
  { year: '2022', event: 'Lancement du Programme Veuves — 15 veuves inscrites en formation professionnelle' },
  { year: '2023', event: "Programme d'éducation — 20 orphelins parrainés pour l'école" },
  { year: '2024', event: 'Expansion à 5 communautés — premier puits d\'eau potable achevé (300+ desservis)' },
  { year: '2025', event: '200+ vies impactées — nettoyage communautaire mobilise 200 bénévoles' },
  { year: '2026', event: 'Partenariats institutionnels canadiens — planification du deuxième puits et centre de formation' },
];

try {
  const page = await getAboutPage();
  if (page) {
    if (page.timeline?.length) timeline = page.timeline;
  }
} catch {}

let communityPhotoUrl = '';
try {
  const projectId = import.meta.env.SANITY_PROJECT_ID || 'rj2m21gk';
  const dataset = import.meta.env.SANITY_DATASET || 'production';
  const client = createClient({ projectId, dataset, apiVersion: '2026-03-28', useCdn: true });
  const photo = await client.fetch('*[_type == "galleryImage" && defined(photo)] | order(year desc) [0] { "ref": photo.asset._ref }');
  if (photo?.ref) communityPhotoUrl = sanityImageUrl(photo.ref, 800);
} catch {}
---

<PageLayout title="À Propos" description="Découvrez la mission d'Apoti Development Association pour autonomiser les communautés vulnérables au Cameroun.">
  <PageHero title="À Propos de Nous" subtitle="Association caritative chrétienne autonomisant les communautés vulnérables du Cameroun depuis 2021." badge="Notre Histoire" />

  <!-- Mission -->
  <Section background="white" padding="lg">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900">Notre Mission</h2>
      <p class="mt-6 text-lg text-gray-600 leading-relaxed">{missionStatement}</p>
      <div class="mt-8 grid grid-cols-3 gap-4 max-w-md mx-auto">
        <div class="text-center">
          <p class="text-2xl font-bold text-primary-700">200+</p>
          <p class="text-xs text-gray-500">Vies Changées</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-bold text-primary-700">5</p>
          <p class="text-xs text-gray-500">Communautés</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-bold text-primary-700">80%</p>
          <p class="text-xs text-gray-500">Aux Programmes</p>
        </div>
      </div>
    </div>
  </Section>

  <!-- Notre Histoire + Photo -->
  <Section background="gray" padding="lg">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900 text-center">Appelés à Servir</h2>
      <div class="mt-8 grid grid-cols-1 md:grid-cols-5 gap-8 items-start">
        <div class="md:col-span-3 space-y-4 text-gray-600 leading-relaxed">
          {storyParagraphs.map(p => <p>{p}</p>)}
        </div>
        {communityPhotoUrl && (
          <div class="md:col-span-2">
            <img src={communityPhotoUrl} alt="Programme communautaire ADA en action" class="w-full rounded-2xl shadow-lg" loading="lazy" />
          </div>
        )}
      </div>
    </div>
  </Section>

  <!-- Vidéo d'Impact -->
  <Section background="white" padding="lg">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900">Voyez Notre Impact</h2>
      <p class="mt-4 text-lg text-gray-600">Découvrez comment votre soutien transforme des vies dans nos communautés.</p>
      <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <video controls preload="metadata" class="w-full aspect-video bg-gray-900" aria-label="Vidéo du programme Rentrée Scolaire ADA">
            <source src="https://cdn.sanity.io/files/rj2m21gk/production/6d43bdec66014a0bddb4702538982688a8ec4412.mp4" type="video/mp4" />
            Votre navigateur ne supporte pas la balise vidéo.
          </video>
          <p class="p-3 text-sm text-gray-600 bg-gray-50">Programme Rentrée Scolaire 2022</p>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <video controls preload="metadata" class="w-full aspect-video bg-gray-900" aria-label="Vidéo d'action communautaire ADA">
            <source src="https://cdn.sanity.io/files/rj2m21gk/production/02cbff013caef81d8c01e96e68f95cb364ce3a01.mp4" type="video/mp4" />
            Votre navigateur ne supporte pas la balise vidéo.
          </video>
          <p class="p-3 text-sm text-gray-600 bg-gray-50">Action Communautaire</p>
        </div>
      </div>
    </div>
  </Section>

  <!-- Valeurs -->
  <Section background="gray" padding="lg">
    <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900 text-center">Nos Valeurs</h2>
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {coreValues.map((v) => (
        <div class="p-6 bg-gray-50 rounded-card shadow-card border-t-2 border-transparent hover:border-primary-500 hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
          <span class="text-3xl">{v.icon}</span>
          <h3 class="mt-3 text-lg font-semibold text-gray-900">{v.title}</h3>
          <p class="mt-2 text-sm text-gray-600">{v.desc}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- Programmes (liés aux pages projets) -->
  <Section background="gray" padding="lg">
    <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900 text-center">Nos Programmes</h2>
    <p class="mt-4 text-lg text-gray-600 text-center max-w-2xl mx-auto">Six programmes ciblés répondant aux besoins les plus pressants de nos communautés.</p>
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {programs.map((program) => (
        <a href={`/fr/projects/${program.slug}`} class="group block p-6 bg-white rounded-card shadow-card border-t-2 border-transparent hover:border-primary-500 hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
          <span class="text-3xl">{program.icon}</span>
          <h3 class="mt-3 text-lg font-semibold text-gray-900 group-hover:text-primary-700 transition-colors">{program.title}</h3>
          <p class="mt-2 text-sm text-gray-600">{program.desc}</p>
          <span class="mt-3 inline-block text-xs font-medium text-primary-600 group-hover:text-primary-700">En savoir plus →</span>
        </a>
      ))}
    </div>
  </Section>

  <!-- Chronologie -->
  <Section background="white" padding="lg">
    <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900 text-center">Notre Parcours</h2>
    <div class="mt-12 max-w-3xl mx-auto">
      <div class="relative">
        <div class="absolute left-8 top-0 bottom-0 w-0.5 bg-primary-200" aria-hidden="true"></div>
        <ol class="space-y-8 list-none">
          {timeline.map((milestone) => (
            <li class="relative flex gap-6">
              <div class="flex-shrink-0 w-16 h-16 rounded-full bg-primary-600 flex items-center justify-center z-10 shadow-md">
                <span class="text-white font-bold text-sm">{milestone.year}</span>
              </div>
              <div class="pt-4">
                <p class="text-gray-700 font-medium leading-relaxed">{milestone.event}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </Section>

  <!-- CTA -->
  <Section background="dark" padding="lg" class="!bg-gray-900 !bg-none">
    <div class="text-center">
      <h2 class="text-3xl md:text-4xl font-heading font-bold">Rejoignez Notre Mission</h2>
      <p class="mt-4 text-white/80 max-w-2xl mx-auto">Que ce soit par un don, le bénévolat ou la prière, vous pouvez faire la différence dans la vie des veuves, orphelins et jeunes femmes au Cameroun.</p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/fr/donate" class="inline-flex items-center px-6 py-3 text-base font-semibold text-primary-800 bg-white rounded-lg hover:bg-gray-100 transition-colors">Faire un Don</a>
        <a href="/fr/get-involved" class="inline-flex items-center px-6 py-3 text-base font-semibold text-white border-2 border-white/30 rounded-lg hover:bg-white/10 transition-colors">S'Impliquer</a>
        <a href="/fr/team" class="inline-flex items-center px-6 py-3 text-base font-semibold text-white border-2 border-white/30 rounded-lg hover:bg-white/10 transition-colors">Notre Équipe</a>
      </div>
    </div>
  </Section>
</PageLayout>
