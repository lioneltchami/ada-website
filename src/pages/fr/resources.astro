---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/layout/PageHero.astro';
import DocumentLibrary from '../../components/resources/DocumentLibrary.astro';
import { getLocale, t, localePath } from '../../i18n';
import { REGISTRATION_CERTIFICATE_URL } from '../../data/organization';
import { loadProjectDocumentLibrary } from '../../lib/project-archive';

const locale = getLocale(Astro.url.pathname);
const labels = t(locale);
const { yearGroups, totalProjects } = await loadProjectDocumentLibrary();

const dueDiligenceDocs = [
  {
    title: 'Enregistrement Légal',
    desc: "Certificat officiel d'enregistrement d'ONG (Cameroun)",
    link: REGISTRATION_CERTIFICATE_URL,
    external: true,
    icon: '📜',
  },
  {
    title: "Conseil d'Administration",
    desc: 'Membres actuels du conseil et structure de gouvernance',
    link: localePath('/team', locale),
    external: false,
    icon: '👥',
    action: labels.resources.openLink,
  },
  {
    title: 'Politique de Protection',
    desc: "Notre engagement pour la protection de l'enfance",
    link: '/docs/policies/safeguarding.md',
    external: true,
    icon: '🛡️',
    action: labels.resources.openLink,
  },
  {
    title: 'Gestion Financière',
    desc: 'Contrôles internes et politiques anti-corruption',
    link: '/docs/policies/financial-management.md',
    external: true,
    icon: '📑',
    action: labels.resources.openLink,
  },
];

const libraryLabels = {
  annualReports: labels.resources.annualReports,
  projectDocs: labels.resources.projectDocs,
  projectDocsIntro: labels.resources.projectDocsIntro,
  funderDocs: labels.resources.funderDocs,
  funderDocsDesc: labels.resources.funderDocsDesc,
  tor: labels.resources.tor,
  financials: labels.resources.financials,
  completionReport: labels.resources.completionReport,
  download: labels.resources.download,
  openLink: labels.resources.openLink,
  annualReportForYear: labels.resources.annualReportForYear,
  projectsInYear: labels.resources.projectsInYear,
  demographics: labels.resources.demographics,
};
---

<PageLayout title={labels.resources.title} description={labels.resources.subtitle}>
  <PageHero title={labels.resources.title} subtitle={labels.resources.subtitle} compact />

  <DocumentLibrary
    locale={locale}
    labels={libraryLabels}
    dueDiligenceDocs={dueDiligenceDocs}
    yearGroups={yearGroups}
    totalProjects={totalProjects}
  />
</PageLayout>
