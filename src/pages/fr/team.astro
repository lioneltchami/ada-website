---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/layout/PageHero.astro';
import Section from '../../components/layout/Section.astro';
import { getTeamMembers, getImpactMetrics } from '../../lib/sanity';

let teamMembers: { name: string; role: string; bio: string }[] = [];
try { const m = await getTeamMembers(); if (m?.length) teamMembers = m.map((m: any) => ({ name: m.name, role: m.role, bio: m.bio || '' })); } catch {}

let teamStats = [{ value: '10', label: 'Bénévoles Actifs' }, { value: '5', label: 'Années de Service' }, { value: '5', label: 'Communautés' }];
try {
  const metrics = await getImpactMetrics();
  if (metrics?.length) {
    const communities = metrics.find(m => m.label.includes('Communities'));
    const years = metrics.find(m => m.label.includes('Years'));
    teamStats = [{ value: '10', label: 'Bénévoles Actifs' }, { value: years ? `${years.value}${years.suffix || ''}` : '5', label: 'Années de Service' }, { value: communities ? `${communities.value}` : '5', label: 'Communautés' }];
  }
} catch {}
---

<PageLayout title="Notre Équipe" description="Rencontrez l'équipe dévouée derrière Apoti Development Association.">
  <PageHero title="Notre Équipe" subtitle="Des personnes dévouées travaillant ensemble pour servir les communautés vulnérables." badge="Les Personnes Derrière ADA" compact />
  <Section background="white" padding="lg">
    {teamMembers.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {teamMembers.map((member) => (
          <div class="text-center">
            <div class="w-32 h-32 mx-auto rounded-full bg-primary-100 flex items-center justify-center">
              <span class="text-3xl font-bold text-primary-600">{member.name.split(' ').map(n => n[0]).join('')}</span>
            </div>
            <h3 class="mt-4 text-lg font-semibold text-gray-900">{member.name}</h3>
            <p class="text-sm text-primary-600">{member.role}</p>
            <p class="mt-2 text-sm text-gray-600">{member.bio}</p>
          </div>
        ))}
      </div>
    ) : (
      <div class="text-center py-12">
        <span class="text-5xl">👥</span>
        <h2 class="mt-4 text-xl font-semibold text-gray-900">Profils à Venir</h2>
        <p class="mt-2 text-gray-600">Les profils de notre équipe seront bientôt disponibles.</p>
      </div>
    )}
  </Section>
  <Section background="gray" padding="md">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
      {teamStats.map((stat) => (<div><p class="text-3xl font-bold text-primary-700">{stat.value}</p><p class="mt-1 text-sm text-gray-600">{stat.label}</p></div>))}
    </div>
  </Section>
  <Section background="dark" padding="md">
    <div class="text-center">
      <h2 class="text-2xl font-heading font-bold">Rejoignez Notre Équipe</h2>
      <p class="mt-2 text-white/80">Nous recherchons toujours des bénévoles passionnés.</p>
      <a href="/fr/get-involved" class="mt-4 inline-flex items-center px-6 py-3 text-base font-semibold text-primary-800 bg-white rounded-lg hover:bg-gray-100 transition-colors">S'Impliquer</a>
    </div>
  </Section>
</PageLayout>
