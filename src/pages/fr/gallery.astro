---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/layout/PageHero.astro';
import Section from '../../components/layout/Section.astro';
import { getGalleryImages } from '../../lib/sanity';

const categoryMap: Record<string, string> = { 'food-distribution': 'Distribution Alimentaire', 'skills-training': 'Formation', 'education': 'Éducation', 'community': 'Communauté', 'events': 'Événements' };

let galleryImages: { title: string; category: string }[] = [];
try { const imgs = await getGalleryImages(); if (imgs?.length) galleryImages = imgs.map((img: any) => ({ title: img.title, category: img.category || 'community' })); } catch {}

let categories = ['Tout', 'Distribution Alimentaire', 'Formation', 'Éducation', 'Communauté'];
if (galleryImages.length > 0) {
  const uniqueCats = [...new Set(galleryImages.map(img => img.category))];
  categories = ['Tout', ...uniqueCats.map(c => categoryMap[c] || c)];
}
---

<PageLayout title="Galerie" description="Photos et moments des programmes d'ADA au Cameroun.">
  <PageHero title="Galerie" subtitle="Moments d'impact, d'espoir et de transformation de nos programmes." badge="Notre Travail en Images" compact />
  <Section background="white" padding="lg">
    <div class="flex flex-wrap gap-2 mb-8">
      {categories.map((cat, i) => (<button class:list={["px-4 py-2 text-sm font-medium rounded-full transition-colors", i === 0 ? "bg-primary-600 text-white" : "bg-gray-100 text-gray-700 hover:bg-gray-200"]}>{cat}</button>))}
    </div>
    {galleryImages.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {galleryImages.map((img) => (<div class="aspect-[4/3] bg-gradient-to-br from-primary-100 to-primary-200 rounded-card flex items-center justify-center"><div class="text-center"><span class="text-4xl">📷</span><p class="mt-2 text-sm text-primary-700">{img.title}</p></div></div>))}
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {Array.from({ length: 9 }).map((_, i) => (<div class="aspect-[4/3] bg-gradient-to-br from-primary-100 to-primary-200 rounded-card flex items-center justify-center"><div class="text-center"><span class="text-4xl">📷</span><p class="mt-2 text-sm text-primary-700">Photo {i + 1}</p><p class="text-xs text-primary-600/60">Télécharger via Sanity CMS</p></div></div>))}
      </div>
    )}
  </Section>
</PageLayout>
