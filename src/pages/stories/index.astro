---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/layout/PageHero.astro';
import Section from '../../components/layout/Section.astro';
import { getBlogPosts, type SanityBlogPost } from '../../lib/sanity';

const metaTitle = 'Stories & Updates';
const metaDescription = 'Read stories of impact, program updates, and announcements from Apoti Development Association.';

let posts: SanityBlogPost[] = [];
try {
  posts = await getBlogPosts();
} catch {}
---

<PageLayout title={metaTitle} description={metaDescription}>
  <PageHero title="Stories & Updates" subtitle="News, impact stories, and announcements from our programs." badge="Our Blog" compact />

  <Section background="white" padding="lg">
    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <a href={`/stories/${post.slug.current}`} class="group">
            <article class="p-6 bg-gray-50 rounded-card shadow-card hover:shadow-card-hover transition-shadow">
              <span class="text-xs font-medium text-primary-600 uppercase">{post.category || 'update'}</span>
              <h2 class="mt-2 text-lg font-semibold text-gray-900 group-hover:text-primary-700 transition-colors">{post.title}</h2>
              <p class="mt-2 text-sm text-gray-600 line-clamp-3">{post.excerpt}</p>
              {post.publishedAt && <p class="mt-3 text-xs text-gray-400">{new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>}
            </article>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-12">
        <span class="text-5xl">✍️</span>
        <h2 class="mt-4 text-xl font-semibold text-gray-900">Stories Coming Soon</h2>
        <p class="mt-2 text-gray-600">We're working on sharing more stories of impact. Check back soon!</p>
      </div>
    )}
  </Section>
</PageLayout>
