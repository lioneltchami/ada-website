---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/layout/PageHero.astro';
import Section from '../../components/layout/Section.astro';
import { getBlogPosts, type SanityBlogPost } from '../../lib/sanity';

let posts: SanityBlogPost[] = [];
try { posts = await getBlogPosts(); } catch {}

const categories = ['all', 'story', 'update', 'announcement'];
const categoryLabels: Record<string, string> = {
  all: 'All',
  story: 'Stories',
  update: 'Updates',
  announcement: 'Announcements',
};
---

<PageLayout title="Stories & Updates" description="Read stories of impact, program updates, and announcements from Apoti Development Association.">
  <PageHero title="Stories & Updates" subtitle="News, impact stories, and announcements from our programs." badge="Our Blog" compact />

  <Section background="white" padding="lg">
    {posts.length > 0 ? (
      <div>
        <!-- Category Filters -->
        <div class="flex flex-wrap gap-2 mb-8" id="story-filters">
          {categories.map((cat) => (
            <button
              data-filter={cat}
              class:list={["px-4 py-2 text-sm font-medium rounded-full transition-colors", cat === 'all' ? "bg-primary-600 text-white" : "bg-gray-100 text-gray-700 hover:bg-gray-200"]}
            >
              {categoryLabels[cat]} ({cat === 'all' ? posts.length : posts.filter(p => p.category === cat).length})
            </button>
          ))}
        </div>

        <!-- Posts Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="stories-grid">
          {posts.map((post) => (
            <a href={`/stories/${post.slug.current}`} class="group story-card" data-category={post.category || 'update'}>
              <article class="h-full p-6 bg-gray-50 rounded-xl border border-gray-100 hover:border-primary-200 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
                <div class="flex items-center gap-2 mb-3">
                  <span class:list={["px-2 py-0.5 text-[10px] font-semibold uppercase rounded-full", post.category === 'story' ? 'bg-purple-100 text-purple-700' : post.category === 'announcement' ? 'bg-blue-100 text-blue-700' : 'bg-green-100 text-green-700']}>
                    {post.category || 'update'}
                  </span>
                  {post.publishedAt && (
                    <time class="text-xs text-gray-400">{new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}</time>
                  )}
                </div>
                <h2 class="text-lg font-semibold text-gray-900 group-hover:text-primary-700 transition-colors leading-tight">{post.title}</h2>
                <p class="mt-3 text-sm text-gray-600 line-clamp-3 leading-relaxed">{post.excerpt}</p>
                <span class="mt-4 inline-block text-sm font-medium text-primary-600 group-hover:text-primary-700">Read more →</span>
              </article>
            </a>
          ))}
        </div>
      </div>
    ) : (
      <div class="text-center py-12">
        <span class="text-5xl">✍️</span>
        <h2 class="mt-4 text-xl font-semibold text-gray-900">Stories Coming Soon</h2>
        <p class="mt-2 text-gray-600">We're working on sharing more stories of impact. Check back soon!</p>
      </div>
    )}
  </Section>

  <Section background="gray" padding="sm">
    <div class="text-center">
      <a href="/gallery" class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-primary-700 border border-primary-200 rounded-lg hover:bg-primary-50 transition-colors">
        📷 View Photo Gallery →
      </a>
    </div>
  </Section>
</PageLayout>

<script>
  const buttons = document.querySelectorAll('#story-filters button');
  const cards = document.querySelectorAll('.story-card');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');

      // Update button styles
      buttons.forEach(b => {
        b.classList.remove('bg-primary-600', 'text-white');
        b.classList.add('bg-gray-100', 'text-gray-700');
      });
      btn.classList.remove('bg-gray-100', 'text-gray-700');
      btn.classList.add('bg-primary-600', 'text-white');

      // Filter cards
      cards.forEach(card => {
        if (filter === 'all' || card.getAttribute('data-category') === filter) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
