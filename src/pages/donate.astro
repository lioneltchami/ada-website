---
import PageLayout from "../layouts/PageLayout.astro";
import Section from "../components/layout/Section.astro";
import DonationForm from "../components/islands/DonationForm";
import { getDonationTiers, getProjects, getSiteSettings, sanityImageUrl, type SanityDonationTier, type SanityProject } from '../lib/sanity';

let contactEmail = 'info@apotidev.org';
try {
  const settings = await getSiteSettings();
  if (settings?.contactEmail) contactEmail = settings.contactEmail;
} catch {}

const pageTitle = 'Make a Difference';
const pageSubtitle = 'Every contribution helps us reach more vulnerable communities in Cameroon.';
const pageBadge = 'Support Our Mission';

const trustIndicators = [
  { icon: '🔒', text: 'Secure & Encrypted' },
  { icon: '📊', text: '80% to Direct Aid' },
  { icon: '📧', text: 'Receipt Emailed Instantly' },
];

const otherWaysToGive = [
  { icon: '📦', title: 'In-Kind Donations', description: `Contact <a href="mailto:${contactEmail}" class="text-primary-600 hover:underline">${contactEmail}</a>` },
  { icon: '🏢', title: 'Corporate Matching', description: 'Ask your employer about matching programs' },
  { icon: '💌', title: 'Legacy Giving', description: '<a href="/contact" class="text-primary-600 hover:underline">Contact us</a> to learn more' },
];

let impactExamples = [
  { amount: '$25', impact: 'School supplies for 2 children' },
  { amount: '$50', impact: 'Widow support for a week' },
  { amount: '$100', impact: 'Skills training for one woman' },
  { amount: '$250', impact: 'Healthcare for 5 families' },
  { amount: '$500', impact: 'Agricultural training for 3 farmers' },
  { amount: '$1,000', impact: 'Community clean-up initiative' },
];

let projectOptions: { slug: string; title: string }[] = [];
let heroImageUrl = '';
try {
  const projects = await getProjects();
  if (projects?.length) {
    projectOptions = projects
      .filter((p: SanityProject) => p.status === 'active')
      .map((p: SanityProject) => ({ slug: p.slug.current, title: p.title }));
    const withImage = projects.find((p: SanityProject) => p.mainImage?.asset?._ref && p.slug?.current === 'widow-support');
    if (withImage) heroImageUrl = sanityImageUrl(withImage.mainImage!.asset._ref, 1200);
  }
} catch {}

try {
  const tiers = await getDonationTiers();
  if (tiers?.length) {
    impactExamples = tiers.map((t: SanityDonationTier) => ({
      amount: `$${t.amount.toLocaleString()}`,
      impact: t.impactDescription,
    }));
  }
} catch {}
---

<PageLayout title="Donate" description="Support ADA's mission to empower vulnerable communities in Cameroon. Every contribution makes a difference.">
  <!-- Hero with background image -->
  <section class="relative overflow-hidden py-20 md:py-28 text-white">
    {heroImageUrl ? (
      <img src={heroImageUrl} alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
    ) : null}
    <div class="absolute inset-0 bg-gradient-to-br from-primary-900/90 via-primary-800/85 to-primary-900/90"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block px-4 py-1.5 mb-4 text-sm font-medium bg-white/10 backdrop-blur-sm rounded-full border border-white/20">{pageBadge}</span>
      <h1 class="text-4xl md:text-5xl font-heading font-bold leading-tight">{pageTitle}</h1>
      <p class="mt-4 text-lg md:text-xl text-white/80 max-w-2xl mx-auto leading-relaxed">{pageSubtitle}</p>
    </div>
  </section>

  <!-- Trust Indicators -->
  <Section background="white" padding="sm">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-center">
      {trustIndicators.map((item) => (
        <div class="flex items-center justify-center gap-2">
          <span>{item.icon}</span>
          <span class="text-sm text-gray-600">{item.text}</span>
        </div>
      ))}
    </div>
  </Section>

  <!-- Donation Form -->
  <Section background="gray" padding="lg">
    <DonationForm client:load projects={projectOptions} />
  </Section>

  <!-- Impact Examples -->
  <Section background="white" padding="lg">
    <h2 class="text-2xl font-heading font-bold text-gray-900 text-center">Your Impact</h2>
    <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-3xl mx-auto">
      {impactExamples.map((item) => (
        <div class="flex items-center gap-3 p-3 bg-primary-50 rounded-lg">
          <span class="text-lg font-bold text-primary-700">{item.amount}</span>
          <span class="text-sm text-gray-700">= {item.impact}</span>
        </div>
      ))}
    </div>
  </Section>

  <!-- Other Ways to Give -->
  <Section background="gray" padding="md">
    <h2 class="text-2xl font-heading font-bold text-gray-900 text-center">Other Ways to Give</h2>
    <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-6 max-w-3xl mx-auto">
      {otherWaysToGive.map((item) => (
        <div class="text-center">
          <span class="text-2xl">{item.icon}</span>
          <h3 class="mt-2 text-sm font-semibold text-gray-900">{item.title}</h3>
          <p class="mt-1 text-xs text-gray-600" set:html={item.description} />
        </div>
      ))}
    </div>
  </Section>
</PageLayout>
