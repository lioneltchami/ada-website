---
import PageLayout from '../../layouts/PageLayout.astro';
import Section from '../../components/layout/Section.astro';
import NewsletterSignup from '../../components/islands/NewsletterSignup';
---

<PageLayout title="Thank You" description="Your donation has been received. Thank you for supporting ADA." noIndex>
  <Section background="white" padding="lg">
    <div class="max-w-lg mx-auto text-center">
      <span class="text-5xl">🎉</span>
      <h1 class="mt-4 text-3xl font-heading font-bold text-gray-900">Thank You!</h1>
      <p class="mt-4 text-lg text-gray-600">
        Your generous donation has been received. A receipt has been sent to your email.
      </p>
      <p class="mt-2 text-gray-500">
        Your support makes a real difference in the lives of vulnerable communities in Cameroon.
      </p>
    </div>
  </Section>

  <!-- Monthly Upsell -->
  <Section background="primary" padding="sm">
    <div class="max-w-lg mx-auto text-center">
      <p class="text-sm font-semibold text-primary-800">💚 Make it monthly?</p>
      <p class="mt-1 text-xs text-primary-700">Monthly donors provide predictable support that helps us plan ahead for the 15 widows counting on us.</p>
      <a href="/donate" class="mt-3 inline-flex items-center px-4 py-2 text-sm font-semibold text-white bg-primary-600 rounded-lg hover:bg-primary-700 transition-colors">
        Become a Monthly Supporter
      </a>
    </div>
  </Section>

  <!-- Share -->
  <Section background="white" padding="md">
    <div class="max-w-lg mx-auto text-center">
      <h2 class="text-lg font-semibold text-gray-900">Spread the Word</h2>
      <p class="mt-1 text-sm text-gray-600">Help us reach more people by sharing your support.</p>
      <div class="mt-4 flex items-center justify-center gap-3">
        <a href="https://twitter.com/intent/tweet?text=I%20just%20donated%20to%20Apoti%20Development%20Association%20%E2%80%94%20supporting%20widows%2C%20orphans%2C%20and%20young%20women%20in%20Cameroon.%20Join%20me%3A%20https%3A%2F%2Fapotidev.org%2Fdonate" target="_blank" rel="noopener" class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">
          Share on X
        </a>
        <a href="https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Fapotidev.org%2Fdonate" target="_blank" rel="noopener" class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">
          Share on Facebook
        </a>
        <a href="https://wa.me/?text=I%20just%20donated%20to%20ADA%20%E2%80%94%20supporting%20communities%20in%20Cameroon.%20Join%20me%3A%20https%3A%2F%2Fapotidev.org%2Fdonate" target="_blank" rel="noopener" class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">
          WhatsApp
        </a>
      </div>
    </div>
  </Section>

  <!-- Newsletter -->
  <Section background="gray" padding="md">
    <div class="max-w-lg mx-auto text-center">
      <h2 class="text-lg font-semibold text-gray-900">See Your Impact</h2>
      <p class="mt-1 text-sm text-gray-600">Get monthly updates with photos and stories showing how your donation is making a difference.</p>
      <div class="mt-4">
        <NewsletterSignup client:visible />
      </div>
    </div>
  </Section>

  <!-- Navigation -->
  <Section background="white" padding="sm">
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
      <a href="/" class="px-5 py-2.5 text-sm font-semibold text-white bg-primary-600 rounded-lg hover:bg-primary-700 transition-colors">
        Return Home
      </a>
      <a href="/stories" class="px-5 py-2.5 text-sm font-medium text-primary-700 border border-primary-200 rounded-lg hover:bg-primary-50 transition-colors">
        Read Impact Stories
      </a>
    </div>
  </Section>
</PageLayout>
