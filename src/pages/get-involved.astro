---
import PageLayout from "../layouts/PageLayout.astro";
import PageHero from "../components/layout/PageHero.astro";
import Section from "../components/layout/Section.astro";
import { getVolunteerRoles, getSiteSettings, type SanityVolunteerRole } from '../lib/sanity';

let socialFacebook = 'https://facebook.com/apotidev';
let socialInstagram = 'https://instagram.com/apotidev';
let socialTwitter = 'https://twitter.com/apotidev';

try {
  const settings = await getSiteSettings();
  if (settings) {
    socialFacebook = settings.socialFacebook || socialFacebook;
    socialInstagram = settings.socialInstagram || socialInstagram;
    socialTwitter = settings.socialTwitter || socialTwitter;
  }
} catch {}

// TODO: Move to Sanity schema when partnershipTier type is created
const partnershipTiers = [
  { tier: "Community Partner", range: "$500–$2,000/year", desc: "Logo on website, quarterly impact reports, social media recognition." },
  { tier: "Program Sponsor", range: "$2,000–$5,000/year", desc: "Sponsor a full program cycle, naming rights, annual site visit, dedicated reporting." },
  { tier: "Strategic Alliance", range: "$5,000+/year", desc: "Multi-year partnership, board advisory role, co-branded campaigns." },
];

const fallbackRoles = [
  { title: 'Community Outreach Coordinator', time: '10-15 hrs/week', location: 'On-site', desc: 'Lead community engagement and program delivery.' },
  { title: 'Education Mentor', time: '5-10 hrs/week', location: 'On-site', desc: 'Tutor and mentor orphaned children in our education program.' },
  { title: 'Skills Training Facilitator', time: '8-12 hrs/week', location: 'On-site', desc: 'Teach vocational skills to young women.' },
  { title: 'Healthcare Support Volunteer', time: '5-8 hrs/week', location: 'On-site', desc: 'Assist with hospital visits and health awareness campaigns.' },
  { title: 'Digital Media & Communications', time: '5-10 hrs/week', location: 'Remote', desc: 'Manage social media, create content, and tell our story.' },
  { title: 'Fundraising & Events', time: 'Flexible', location: 'Remote', desc: 'Help plan campaigns and coordinate fundraising events.' },
];

let volunteerRoles = fallbackRoles;
try {
  const roles = await getVolunteerRoles();
  if (roles?.length) {
    volunteerRoles = roles.map((r: SanityVolunteerRole) => ({
      title: r.title,
      time: r.timeCommitment,
      location: r.location,
      desc: r.description,
    }));
  }
} catch {}

const metaTitle = 'Get Involved';
const metaDescription = 'Join ADA as a volunteer, monthly supporter, or corporate partner. Multiple ways to make a difference.';
---

<PageLayout title={metaTitle} description={metaDescription}>
  <PageHero
    title="Get Involved"
    subtitle="There are many ways to support our mission. Find the one that's right for you."
    badge="Make a Difference"
  />

  <!-- Ways to Help -->
  <Section background="white" padding="lg">
    <h2 class="text-3xl font-heading font-bold text-gray-900 text-center">Ways to Help</h2>
    <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {[
        { icon: "🙋", title: "Volunteer", desc: "Give your time and skills", href: "#volunteer" },
        { icon: "💝", title: "Monthly Giving", desc: "Join our giving community", href: "/donate" },
        { icon: "📢", title: "Advocate", desc: "Share our mission with others", href: "#advocate" },
        { icon: "🏢", title: "Partner", desc: "Corporate partnerships", href: "#partnerships" },
      ].map((way) => (
        <a href={way.href} class="p-6 bg-gray-50 rounded-card hover:bg-primary-50 transition-colors text-center group">
          <span class="text-3xl">{way.icon}</span>
          <h3 class="mt-3 text-lg font-semibold text-gray-900 group-hover:text-primary-700">{way.title}</h3>
          <p class="mt-1 text-sm text-gray-600">{way.desc}</p>
        </a>
      ))}
    </div>
  </Section>

  <!-- Volunteer Opportunities -->
  <Section id="volunteer" background="gray" padding="lg">
    <h2 class="text-3xl font-heading font-bold text-gray-900 text-center">Volunteer Opportunities</h2>
    <p class="mt-4 text-gray-600 text-center max-w-2xl mx-auto">
      We have roles for every skill set and availability.
    </p>
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {volunteerRoles.map((role) => (
        <div class="p-5 bg-white rounded-card shadow-card border-t-2 border-transparent hover:border-primary-500 hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
          <h3 class="text-base font-semibold text-gray-900">{role.title}</h3>
          <div class="mt-2 flex gap-2">
            <span class="px-2 py-0.5 text-xs bg-primary-100 text-primary-700 rounded-full">{role.time}</span>
            <span class="px-2 py-0.5 text-xs bg-gray-100 text-gray-600 rounded-full">{role.location}</span>
          </div>
          <p class="mt-3 text-sm text-gray-600">{role.desc}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- Volunteer Form -->
  <Section background="white" padding="lg">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl font-heading font-bold text-gray-900 text-center">Apply to Volunteer</h2>
      <form class="mt-8 space-y-4" id="volunteer-form">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="vol-name" class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
            <input type="text" id="vol-name" name="name" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" />
          </div>
          <div>
            <label for="vol-email" class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
            <input type="email" id="vol-email" name="email" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" />
          </div>
        </div>
        <div>
          <label for="vol-role" class="block text-sm font-medium text-gray-700 mb-1">Preferred Role</label>
          <select id="vol-role" name="role" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
            <option value="">Select a role...</option>
            {volunteerRoles.map((r) => <option value={r.title}>{r.title}</option>)}
          </select>
        </div>
        <div>
          <label for="vol-availability" class="block text-sm font-medium text-gray-700 mb-1">Availability</label>
          <select id="vol-availability" name="availability" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
            <option value="flexible">Flexible</option>
            <option value="full-time">Full-time</option>
            <option value="part-time">Part-time</option>
            <option value="weekends">Weekends only</option>
          </select>
        </div>
        <div>
          <label for="vol-message" class="block text-sm font-medium text-gray-700 mb-1">Why do you want to volunteer?</label>
          <textarea id="vol-message" name="message" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500"></textarea>
        </div>
        <button type="submit" class="w-full sm:w-auto px-6 py-3 text-base font-semibold text-white bg-primary-600 rounded-lg hover:bg-primary-700 transition-colors">
          Submit Application
        </button>
      </form>
    </div>
  </Section>

  <script>
    document.getElementById('volunteer-form')!.addEventListener('submit', (e) => {
      e.preventDefault();
      const btn = (e.target as HTMLFormElement).querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Submitted!';
      const msg = document.createElement('p');
      msg.className = 'mt-4 text-sm text-green-700 font-medium';
      msg.setAttribute('role', 'alert');
      msg.setAttribute('aria-live', 'polite');
      msg.textContent = 'Application submitted! We will be in touch soon.';
      (e.target as HTMLElement).appendChild(msg);
    });
  </script>

  <!-- Corporate Partnerships -->
  <Section id="partnerships" background="gray" padding="lg">
    <h2 class="text-3xl font-heading font-bold text-gray-900 text-center">Corporate Partnerships</h2>
    <p class="mt-4 text-gray-600 text-center max-w-2xl mx-auto">
      Partner with us to create lasting impact in Cameroon.
    </p>
    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8">
      {partnershipTiers.map((p) => (
        <div class="p-6 bg-white rounded-card shadow-card text-center border-t-2 border-transparent hover:border-primary-500 hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
          <h3 class="text-lg font-semibold text-gray-900">{p.tier}</h3>
          <p class="mt-2 text-2xl font-bold text-primary-700">{p.range}</p>
          <p class="mt-3 text-sm text-gray-600">{p.desc}</p>
          <a href="/contact" class="mt-4 inline-block text-sm font-medium text-primary-600 hover:underline">
            Inquire →
          </a>
        </div>
      ))}
    </div>
  </Section>

  <!-- Advocate -->
  <Section id="advocate" background="dark" padding="md">
    <div class="text-center">
      <h2 class="text-2xl font-heading font-bold">Spread the Word</h2>
      <p class="mt-2 text-white/80">Share our mission on social media and help us reach more people.</p>
      <div class="mt-4 flex items-center justify-center gap-4">
        <a href={socialFacebook} target="_blank" rel="noopener" class="px-4 py-2 bg-white/10 rounded-lg text-sm hover:bg-white/20 transition-colors">Facebook</a>
        <a href={socialInstagram} target="_blank" rel="noopener" class="px-4 py-2 bg-white/10 rounded-lg text-sm hover:bg-white/20 transition-colors">Instagram</a>
        <a href={socialTwitter} target="_blank" rel="noopener" class="px-4 py-2 bg-white/10 rounded-lg text-sm hover:bg-white/20 transition-colors">Twitter/X</a>
      </div>
    </div>
  </Section>
</PageLayout>
