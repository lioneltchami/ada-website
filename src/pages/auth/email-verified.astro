---
import PageLayout from '../../layouts/PageLayout.astro';
import Section from '../../components/layout/Section.astro';
---

<PageLayout title="Email Verified" description="Your email has been verified successfully." noIndex>
  <Section background="gray" padding="lg">
    <div class="max-w-md mx-auto text-center">
      <span class="text-5xl">✅</span>
      <h1 class="mt-4 text-2xl font-heading font-bold text-gray-900">Email Verified!</h1>
      <p class="mt-2 text-gray-600">
        Your account is ready. You can now sign in and start supporting our mission.
      </p>
      <a href="/auth/login" class="mt-6 inline-flex items-center px-5 py-2.5 text-sm font-semibold text-white bg-primary-600 rounded-lg hover:bg-primary-700 transition-colors">
        Go to Login
      </a>
    </div>
  </Section>
</PageLayout>
