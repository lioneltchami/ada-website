---
import PageLayout from '../layouts/PageLayout.astro';
import PageHero from '../components/layout/PageHero.astro';
import Section from '../components/layout/Section.astro';
import { getLocale, t } from '../i18n';
import {
  annualReportPdfs,
  impactGrowthByYear,
  indicatorProgress,
  measurableIndicatorsEn,
} from '../data/organization';

const locale = getLocale(Astro.url.pathname);
const labels = t(locale);
const measurableIndicators = measurableIndicatorsEn;
const impactChartMax = Math.max(...impactGrowthByYear.map((item) => item.value));
---

<PageLayout title="Transparency & Accountability" description="ADA's financial reports, registration details, and accountability measures. 80% of every dollar goes directly to programs.">
  <PageHero title="Transparency & Accountability" subtitle="We believe donors deserve complete visibility into how their money is used." badge="Our Commitment" compact />

  <!-- Registration -->
  <Section background="white" padding="lg">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-heading font-bold text-gray-900">{labels.transparency.legalRegistration}</h2>
      <div class="mt-6 p-6 bg-gray-50 rounded-2xl border border-gray-200">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div><p class="text-xs text-gray-500 uppercase tracking-wider">Organization Name</p><p class="mt-1 text-sm font-semibold text-gray-900">Apoti Development Association (ADA)</p></div>
          <div><p class="text-xs text-gray-500 uppercase tracking-wider">Country of Registration</p><p class="mt-1 text-sm font-semibold text-gray-900">Republic of Cameroon</p></div>
          <div><p class="text-xs text-gray-500 uppercase tracking-wider">Legal Status</p><p class="mt-1 text-sm font-semibold text-gray-900">Registered Non-Profit Association</p></div>
          <div><p class="text-xs text-gray-500 uppercase tracking-wider">Year Established</p><p class="mt-1 text-sm font-semibold text-gray-900">2021</p></div>
          <div><p class="text-xs text-gray-500 uppercase tracking-wider">Registration Number</p><p class="mt-1 text-sm font-semibold text-gray-900">N° 415/G.37/D14/VolI/SAAJP</p></div>
          <div><p class="text-xs text-gray-500 uppercase tracking-wider">Governing Law</p><p class="mt-1 text-sm font-semibold text-gray-900">Law No. 90/053 of 19 December 1990 on Freedom of Association</p></div>
        </div>
        <a href="https://cdn.sanity.io/files/rj2m21gk/production/c226e76c904614c95ddc186d942e656f531483a1.pdf" target="_blank" rel="noopener" class="mt-4 inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-primary-700 bg-white border border-primary-200 rounded-lg hover:bg-primary-50 transition-colors"><span aria-hidden="true">📄</span> Download Registration Certificate (PDF)</a>
      </div>
    </div>
  </Section>

  <!-- Governance & Board -->
  <Section background="white" padding="lg">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-heading font-bold text-gray-900">{labels.transparency.governanceStructure}</h2>
      <p class="mt-2 text-gray-600">ADA is governed by a 12-member board with clear separation of powers, financial oversight, and local leadership in Cameroon.</p>

      <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-4 bg-gray-50 rounded-xl border border-gray-100">
          <p class="text-xs text-gray-500 uppercase tracking-wider">Founder & President</p>
          <p class="mt-1 text-sm font-semibold text-gray-900">Lionel Tchami Nfada, MSc</p>
          <p class="text-xs text-gray-500">International (Diaspora Leadership)</p>
        </div>
        <div class="p-4 bg-gray-50 rounded-xl border border-gray-100">
          <p class="text-xs text-gray-500 uppercase tracking-wider">Vice President</p>
          <p class="mt-1 text-sm font-semibold text-gray-900">Yasmiratu Ba'am</p>
        </div>
        <div class="p-4 bg-gray-50 rounded-xl border border-gray-100">
          <p class="text-xs text-gray-500 uppercase tracking-wider">Country Director</p>
          <p class="mt-1 text-sm font-semibold text-gray-900">Naomi Ndababonga</p>
          <p class="text-xs text-gray-500">Buea, SW Region (HQ)</p>
        </div>
        <div class="p-4 bg-gray-50 rounded-xl border border-gray-100">
          <p class="text-xs text-gray-500 uppercase tracking-wider">Regional Coordinator, NW</p>
          <p class="mt-1 text-sm font-semibold text-gray-900">Corrine Mbekenyui</p>
          <p class="text-xs text-gray-500">Bamenda, NW Region</p>
        </div>
        <div class="p-4 bg-gray-50 rounded-xl border border-gray-100">
          <p class="text-xs text-gray-500 uppercase tracking-wider">Secretary General</p>
          <p class="mt-1 text-sm font-semibold text-gray-900">Vera Mbuh</p>
        </div>
        <div class="p-4 bg-gray-50 rounded-xl border border-gray-100">
          <p class="text-xs text-gray-500 uppercase tracking-wider">Treasurer</p>
          <p class="mt-1 text-sm font-semibold text-gray-900">Christy Nkongho</p>
        </div>
        <div class="p-4 bg-gray-50 rounded-xl border border-gray-100">
          <p class="text-xs text-gray-500 uppercase tracking-wider">Financial Secretary</p>
          <p class="mt-1 text-sm font-semibold text-gray-900">Melanie Timbu</p>
        </div>
        <div class="p-4 bg-gray-50 rounded-xl border border-gray-100">
          <p class="text-xs text-gray-500 uppercase tracking-wider">Communications Officer</p>
          <p class="mt-1 text-sm font-semibold text-gray-900">Brenda Itoe</p>
        </div>
        <div class="p-4 bg-gray-50 rounded-xl border border-gray-100">
          <p class="text-xs text-gray-500 uppercase tracking-wider">M&E Officer</p>
          <p class="mt-1 text-sm font-semibold text-gray-900">Nicole Faith</p>
          <p class="text-xs text-gray-500">Philippines (Remote)</p>
        </div>
        <div class="p-4 bg-gray-50 rounded-xl border border-gray-100">
          <p class="text-xs text-gray-500 uppercase tracking-wider">Spiritual Advisors</p>
          <p class="mt-1 text-sm font-semibold text-gray-900">Boris Beye, Florence Ngassam, Lucy Hastings</p>
        </div>
      </div>

      <div class="mt-6 p-4 bg-primary-50 rounded-xl border border-primary-100">
        <p class="text-sm text-primary-800"><strong>Governance Principles:</strong> Clear separation of powers (President ≠ Treasurer ≠ Secretary). Dual financial oversight (Treasurer + Financial Secretary). Local decision-making through Country Director. All executive roles are volunteer — zero paid leadership.</p>
      </div>
    </div>
  </Section>

  <!-- Financial Overview -->
  <Section background="gray" padding="lg">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-heading font-bold text-gray-900">{labels.transparency.financialAccountability}</h2>
      <p class="mt-2 text-gray-600">Our commitment: overhead under 5%, with 80% of funds going directly to program delivery.</p>

      <div class="mt-8 grid grid-cols-3 gap-4 text-center">
        <div class="p-6 bg-white rounded-xl border border-gray-200">
          <p class="text-3xl font-bold text-primary-700">80%</p>
          <p class="mt-1 text-sm text-gray-600">Direct Program Aid</p>
        </div>
        <div class="p-6 bg-white rounded-xl border border-gray-200">
          <p class="text-3xl font-bold text-primary-700">15%</p>
          <p class="mt-1 text-sm text-gray-600">Program Operations</p>
        </div>
        <div class="p-6 bg-white rounded-xl border border-gray-200">
          <p class="text-3xl font-bold text-primary-700">5%</p>
          <p class="mt-1 text-sm text-gray-600">Administration</p>
        </div>
      </div>

      <!-- Year by year -->
      <h3 class="mt-10 text-lg font-semibold text-gray-900">Annual Financial Summary</h3>
      <div class="mt-4 overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200">
              <th class="text-left py-3 px-2 text-gray-700 font-medium">Year</th>
              <th class="text-right py-3 px-2 text-gray-700 font-medium">Total Received</th>
              <th class="text-right py-3 px-2 text-gray-700 font-medium">Programs (80%)</th>
              <th class="text-right py-3 px-2 text-gray-700 font-medium">Operations (15%)</th>
              <th class="text-right py-3 px-2 text-gray-700 font-medium">Admin (5%)</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr><td class="py-3 px-2 font-medium">2022</td><td class="text-right py-3 px-2">$1,200</td><td class="text-right py-3 px-2">$960</td><td class="text-right py-3 px-2">$180</td><td class="text-right py-3 px-2">$60</td></tr>
            <tr><td class="py-3 px-2 font-medium">2023</td><td class="text-right py-3 px-2">$3,400</td><td class="text-right py-3 px-2">$2,720</td><td class="text-right py-3 px-2">$510</td><td class="text-right py-3 px-2">$170</td></tr>
            <tr><td class="py-3 px-2 font-medium">2024</td><td class="text-right py-3 px-2">$6,800</td><td class="text-right py-3 px-2">$5,440</td><td class="text-right py-3 px-2">$1,020</td><td class="text-right py-3 px-2">$340</td></tr>
            <tr><td class="py-3 px-2 font-medium">2025 (YTD)</td><td class="text-right py-3 px-2">$4,500</td><td class="text-right py-3 px-2">$3,600</td><td class="text-right py-3 px-2">$675</td><td class="text-right py-3 px-2">$225</td></tr>
          </tbody>
          <tfoot>
            <tr class="border-t-2 border-gray-300 font-semibold">
              <td class="py-3 px-2">Total</td><td class="text-right py-3 px-2">$15,900</td><td class="text-right py-3 px-2">$12,720</td><td class="text-right py-3 px-2">$2,385</td><td class="text-right py-3 px-2">$795</td>
            </tr>
          </tfoot>
        </table>
      </div>
      <p class="mt-4 text-xs text-gray-500">* All figures in USD. Financial records available upon request. Contact info@apotidev.org for detailed statements.</p>
      <div class="mt-6">
        <h3 class="text-lg font-semibold text-gray-900">Annual Reports</h3>
        <div class="mt-3 space-y-2">
          {annualReportPdfs.map((report) => (
            <a href={report.path} target="_blank" rel="noopener" class="flex items-center gap-2 px-4 py-2 text-sm font-medium text-primary-700 bg-white border border-primary-200 rounded-lg hover:bg-primary-50 transition-colors">
              <span aria-hidden="true">📊</span> {report.year} Annual Report (PDF)
            </a>
          ))}
        </div>
      </div>
    </div>
  </Section>

  <!-- Measurable Results -->
  <Section background="white" padding="lg">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-heading font-bold text-gray-900">{labels.transparency.measurableResults}</h2>
      <p class="mt-2 text-gray-600">We track outcomes, not just outputs. Here are our key indicators with baselines and actuals.</p>

      <div class="mt-8 space-y-6">
        {measurableIndicators.map((r) => (
          <div class="p-5 bg-gray-50 rounded-2xl border border-gray-100">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1">
                <p class="text-sm font-semibold text-gray-900">{r.indicator}</p>
                
                <!-- Progress Bar -->
                <div class="mt-3 w-full bg-gray-200 rounded-full h-2">
                  <div class="bg-primary-600 h-2 rounded-full transition-all duration-1000" style={`width: ${indicatorProgress(r)}%`}></div>
                </div>

                <div class="mt-4 grid grid-cols-1 sm:grid-cols-3 gap-2 text-[10px] uppercase tracking-wider text-gray-500 font-medium">
                  <span>{labels.transparency.baseline}: <span class="text-gray-900 font-bold">{r.baseline}</span></span>
                  <span>{labels.transparency.target}: <span class="text-gray-900 font-bold">{r.target}</span></span>
                  <span>{labels.transparency.actual}: <span class="text-primary-700 font-bold">{r.actual}</span></span>
                </div>
              </div>
              <span class:list={["px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider rounded-full whitespace-nowrap", r.status === 'on-track' ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700']}>
                {r.status === 'on-track' ? labels.transparency.onTrack : labels.transparency.inProgress}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- Impact Growth -->
  <Section background="white" padding="lg">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-heading font-bold text-gray-900">{labels.transparency.historicalTrends}</h2>
      <p class="mt-2 text-gray-600">{labels.transparency.livesImpactedGrowth}</p>
      
      <div class="mt-12 flex items-end justify-between gap-2 h-64 border-b border-gray-200 pb-2">
        {impactGrowthByYear.map((item) => (
          <div class="flex-1 flex flex-col items-center gap-2 group">
            <div class="relative w-full flex flex-col items-center">
              <span class="text-[10px] font-bold text-primary-700 opacity-0 group-hover:opacity-100 transition-opacity mb-1">{item.label}</span>
              <div 
                class="w-full max-w-[40px] bg-primary-100 border-x border-t border-primary-200 rounded-t-lg group-hover:bg-primary-600 transition-all duration-500" 
                style={`height: ${(item.value / impactChartMax) * 180}px`}
              ></div>
            </div>
            <span class="text-xs font-semibold text-gray-500">{item.year}</span>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- Theory of Change -->
  <Section background="gray" padding="lg">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-heading font-bold text-gray-900">{labels.transparency.theoryOfChange}</h2>
      <p class="mt-2 text-gray-600">How we create lasting impact — from crisis to self-sufficiency.</p>

      <div class="mt-8 grid grid-cols-1 md:grid-cols-4 gap-4">
        {[
          { step: '1', title: 'Identify', desc: 'Community leaders refer widows, orphans, and young women in crisis to ADA.' },
          { step: '2', title: 'Stabilize', desc: 'Immediate relief: food packages, school fees, emergency medical support.' },
          { step: '3', title: 'Empower', desc: 'Skills training, mentorship, microfinance — building capacity for independence.' },
          { step: '4', title: 'Sustain', desc: 'Graduates become mentors. Community ownership ensures programs outlive funding.' },
        ].map((s) => (
          <div class="text-center">
            <div class="w-12 h-12 mx-auto rounded-full bg-primary-600 flex items-center justify-center text-white font-bold">{s.step}</div>
            <h3 class="mt-3 text-sm font-semibold text-gray-900">{s.title}</h3>
            <p class="mt-1 text-xs text-gray-600">{s.desc}</p>
          </div>
        ))}
      </div>

      <div class="mt-8 p-4 bg-primary-50 rounded-xl border border-primary-100">
        <p class="text-sm text-primary-800"><strong>Sustainability:</strong> Our model is designed so that each cohort of beneficiaries becomes the next generation of trainers and mentors. When external funding ends, the skills, networks, and community structures remain.</p>
      </div>
    </div>
  </Section>

  <!-- SDG Alignment -->
  <Section background="gray" padding="lg">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-heading font-bold text-gray-900 text-center">{labels.transparency.sdgAlignment}</h2>
      <p class="mt-4 text-gray-600 text-center max-w-2xl mx-auto">ADA's programs directly contribute to 7 of the 17 UN Sustainable Development Goals.</p>
      <div class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="p-4 bg-white rounded-xl border border-gray-200 text-center">
          <div class="w-12 h-12 mx-auto rounded-lg bg-[#E5243B] flex items-center justify-center">
            <span class="text-white font-bold text-sm">1</span>
          </div>
          <h3 class="mt-2 text-xs font-semibold text-gray-900">No Poverty</h3>
          <p class="mt-1 text-[10px] text-gray-500">Widow support, food aid, startup kits</p>
        </div>
        <div class="p-4 bg-white rounded-xl border border-gray-200 text-center">
          <div class="w-12 h-12 mx-auto rounded-lg bg-[#DDA63A] flex items-center justify-center">
            <span class="text-white font-bold text-sm">2</span>
          </div>
          <h3 class="mt-2 text-xs font-semibold text-gray-900">Zero Hunger</h3>
          <p class="mt-1 text-[10px] text-gray-500">Food distribution, emergency relief</p>
        </div>
        <div class="p-4 bg-white rounded-xl border border-gray-200 text-center">
          <div class="w-12 h-12 mx-auto rounded-lg bg-[#C5192D] flex items-center justify-center">
            <span class="text-white font-bold text-sm">4</span>
          </div>
          <h3 class="mt-2 text-xs font-semibold text-gray-900">Quality Education</h3>
          <p class="mt-1 text-[10px] text-gray-500">Back-to-school, mentorship, skills training</p>
        </div>
        <div class="p-4 bg-white rounded-xl border border-gray-200 text-center">
          <div class="w-12 h-12 mx-auto rounded-lg bg-[#FF3A21] flex items-center justify-center">
            <span class="text-white font-bold text-sm">5</span>
          </div>
          <h3 class="mt-2 text-xs font-semibold text-gray-900">Gender Equality</h3>
          <p class="mt-1 text-[10px] text-gray-500">85% women/girls beneficiaries, empowerment programs</p>
        </div>
        <div class="p-4 bg-white rounded-xl border border-gray-200 text-center">
          <div class="w-12 h-12 mx-auto rounded-lg bg-[#26BDE2] flex items-center justify-center">
            <span class="text-white font-bold text-sm">6</span>
          </div>
          <h3 class="mt-2 text-xs font-semibold text-gray-900">Clean Water</h3>
          <p class="mt-1 text-[10px] text-gray-500">Borehole drilling, solar pump, 300+ served</p>
        </div>
        <div class="p-4 bg-white rounded-xl border border-gray-200 text-center">
          <div class="w-12 h-12 mx-auto rounded-lg bg-[#DD1367] flex items-center justify-center">
            <span class="text-white font-bold text-sm">10</span>
          </div>
          <h3 class="mt-2 text-xs font-semibold text-gray-900">Reduced Inequalities</h3>
          <p class="mt-1 text-[10px] text-gray-500">IDP support, crisis-affected communities</p>
        </div>
        <div class="p-4 bg-white rounded-xl border border-gray-200 text-center">
          <div class="w-12 h-12 mx-auto rounded-lg bg-[#3F7E44] flex items-center justify-center">
            <span class="text-white font-bold text-sm">13</span>
          </div>
          <h3 class="mt-2 text-xs font-semibold text-gray-900">Climate Action</h3>
          <p class="mt-1 text-[10px] text-gray-500">Community cleanups, tree planting, waste management</p>
        </div>
      </div>
      <div class="mt-6 p-4 bg-white rounded-xl border border-gray-200">
        <p class="text-sm text-gray-700 text-center"><strong>Alignment with Canada's Feminist International Assistance Policy:</strong> ADA's programming prioritizes gender equality (SDG 5) as a cross-cutting theme. 85% of our direct beneficiaries are women and girls.</p>
      </div>
    </div>
  </Section>

  <!-- Climate & Environmental Stewardship -->
  <Section background="white" padding="lg">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-heading font-bold text-gray-900 text-center">{labels.transparency.environmentalStewardship}</h2>
      <p class="mt-4 text-gray-600 text-center max-w-2xl mx-auto">Every ADA program integrates environmental awareness — because healthy communities need a healthy planet.</p>
      <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="p-5 bg-gray-50 rounded-xl border border-gray-200 border-t-2 border-t-transparent hover:border-t-primary-500 hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
          <span class="text-2xl" aria-hidden="true">💧</span>
          <h3 class="mt-2 text-sm font-semibold text-gray-900">Clean Water Infrastructure</h3>
          <p class="mt-1 text-xs text-gray-600">Our boreholes eliminate reliance on polluted streams, reducing waterborne disease and protecting local water ecosystems from over-extraction.</p>
        </div>
        <div class="p-5 bg-gray-50 rounded-xl border border-gray-200 border-t-2 border-t-transparent hover:border-t-primary-500 hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
          <span class="text-2xl" aria-hidden="true">🌳</span>
          <h3 class="mt-2 text-sm font-semibold text-gray-900">Tree Planting & Reforestation</h3>
          <p class="mt-1 text-xs text-gray-600">Every community clean-up includes tree planting. In 2024, we planted 50 trees across Bamenda — combating deforestation and providing future shade and fruit.</p>
        </div>
        <div class="p-5 bg-gray-50 rounded-xl border border-gray-200 border-t-2 border-t-transparent hover:border-t-primary-500 hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
          <span class="text-2xl" aria-hidden="true">♻️</span>
          <h3 class="mt-2 text-sm font-semibold text-gray-900">Waste Management Education</h3>
          <p class="mt-1 text-xs text-gray-600">Our clean-up campaigns teach waste sorting, composting, and plastic reduction. We partner with local recyclers to create income from collected materials.</p>
        </div>
        <div class="p-5 bg-gray-50 rounded-xl border border-gray-200 border-t-2 border-t-transparent hover:border-t-primary-500 hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
          <span class="text-2xl" aria-hidden="true">🔥</span>
          <h3 class="mt-2 text-sm font-semibold text-gray-900">Clean Cooking Solutions</h3>
          <p class="mt-1 text-xs text-gray-600">We help widows transition from charcoal to gas cooking — reducing indoor air pollution and decreasing demand for charcoal-driven deforestation.</p>
        </div>
      </div>
      <div class="mt-8 p-4 bg-accent-50 rounded-xl border border-accent-100">
        <p class="text-sm text-gray-700"><strong>Our commitment:</strong> By 2027, every ADA program will include a measurable environmental component. We track trees planted, waste collected, and households transitioned to clean cooking.</p>
      </div>
    </div>
  </Section>

  <!-- Accountability Practices -->
  <Section background="gray" padding="md">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-heading font-bold text-gray-900">Accountability Practices</h2>
      <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { title: 'Zero paid leadership', desc: 'All executive roles are volunteer. 100% of salaries go to program staff only.' },
          { title: 'Quarterly reporting', desc: 'Donors and partners receive detailed quarterly impact reports with photos and data.' },
          { title: 'Community oversight', desc: 'Local committees verify beneficiary selection and program delivery.' },
          { title: 'Open books policy', desc: 'Financial records available upon request. Annual summaries published publicly.' },
          { title: 'Beneficiary feedback', desc: 'Regular surveys ensure programs meet actual community needs.' },
          { title: 'Bilingual reporting', desc: 'All reports available in English and French for international partners.' },
        ].map((p) => (
          <div class="p-4 bg-white rounded-lg">
            <p class="text-sm font-semibold text-gray-900">{p.title}</p>
            <p class="mt-1 text-xs text-gray-600">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- CTA -->
  <Section background="dark" padding="md" class="!bg-gray-900 !bg-none">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-2xl font-heading font-bold">Request Detailed Reports</h2>
      <p class="mt-2 text-white/80 text-sm">For institutional partners, we provide: audited financials, logical frameworks, M&E reports, and project proposals.</p>
