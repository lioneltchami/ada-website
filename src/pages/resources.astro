---
import PageLayout from '../layouts/PageLayout.astro';
import PageHero from '../components/layout/PageHero.astro';
import Section from '../components/layout/Section.astro';
import { getLocale, t, localePath } from '../i18n';
import {
  annualReportPdfs,
  archiveProjectTitle,
  documentArchiveProjects,
  REGISTRATION_CERTIFICATE_URL,
} from '../data/organization';

const locale = getLocale(Astro.url.pathname);
const labels = t(locale);

const dueDiligenceDocs = [
  {
    title: locale === 'en' ? 'Legal Registration' : 'Enregistrement Légal',
    desc:
      locale === 'en'
        ? 'Official NGO registration certificate (Cameroon)'
        : "Certificat officiel d'enregistrement d'ONG (Cameroun)",
    link: REGISTRATION_CERTIFICATE_URL,
    external: true,
  },
  {
    title: locale === 'en' ? 'Board of Directors' : "Conseil d'Administration",
    desc:
      locale === 'en'
        ? 'Current board members and governance structure'
        : 'Membres actuels du conseil et structure de gouvernance',
    link: localePath('/team', locale),
    external: false,
  },
  {
    title: locale === 'en' ? 'Safeguarding Policy' : 'Politique de Protection',
    desc:
      locale === 'en'
        ? 'Our commitment to child protection and safety'
        : "Notre engagement pour la protection de l'enfance",
    link: '/docs/policies/safeguarding.md',
    external: true,
  },
  {
    title: locale === 'en' ? 'Financial Management' : 'Gestion Financière',
    desc:
      locale === 'en'
        ? 'Internal controls and anti-corruption policies'
        : 'Contrôles internes et politiques anti-corruption',
    link: '/docs/policies/financial-management.md',
    external: true,
  },
];

const projects = documentArchiveProjects.map((slug) => ({
  slug,
  name: archiveProjectTitle(slug),
}));
---

<PageLayout 
  title={labels.resources.title} 
  description={labels.resources.subtitle}
>
  <PageHero 
    title={labels.resources.title} 
    subtitle={labels.resources.subtitle}
    compact
  />

  <!-- Annual Reports -->
  <Section background="white">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-heading font-bold text-gray-900 mb-8">{labels.resources.annualReports}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {annualReportPdfs.map((report) => (
          <a 
            href={report.path} 
            target="_blank"
            rel="noopener"
            class="group p-6 bg-gray-50 rounded-2xl border border-gray-200 hover:border-primary-300 hover:shadow-md transition-all"
          >
            <div class="text-4xl mb-4 group-hover:scale-110 transition-transform" aria-hidden="true">📊</div>
            <h3 class="text-xl font-bold text-gray-900">{report.year}</h3>
            <p class="text-sm text-gray-500 mt-1">{labels.resources.annualReports}</p>
            <span class="mt-4 inline-flex items-center text-sm font-semibold text-primary-700">
              {labels.resources.download} →
            </span>
          </a>
        ))}
      </div>
    </div>
  </Section>

  <!-- Diligence Raisonnable -->
  <Section background="gray">
    <div class="max-w-5xl mx-auto">
      <div class="mb-8">
        <h2 class="text-3xl font-heading font-bold text-gray-900">{labels.resources.funderDocs}</h2>
        <p class="text-gray-600 mt-2">{labels.resources.funderDocsDesc}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {dueDiligenceDocs.map((doc) => (
          <a 
            href={doc.link} 
            target={doc.external ? '_blank' : '_self'}
            rel={doc.external ? 'noopener' : undefined}
            class="flex gap-4 p-6 bg-white rounded-2xl border border-gray-200 hover:shadow-md transition-all"
          >
            <div class="w-12 h-12 rounded-xl bg-primary-50 flex items-center justify-center shrink-0">
              <span class="text-2xl">📋</span>
            </div>
            <div>
              <h3 class="font-bold text-gray-900">{doc.title}</h3>
              <p class="text-sm text-gray-600 mt-1">{doc.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </Section>

  <!-- Archive des Projets -->
  <Section background="white">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-heading font-bold text-gray-900 mb-2">{labels.resources.projectDocs}</h2>
      <p class="text-sm text-gray-600 mb-8">
        {locale === 'en'
          ? `${projects.length} completed and active projects with TOR, financial, and completion reports.`
          : `${projects.length} projets avec TDR, rapports financiers et rapports de fin.`}
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {projects.map((project) => (
          <div class="p-6 rounded-2xl border border-gray-100 bg-gray-50/50">
            <h3 class="text-lg font-bold text-gray-900 mb-4">{project.name}</h3>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
              <a 
                href={`/docs/projects/${project.slug}/tor.pdf`} 
                target="_blank"
                rel="noopener"
                class="flex flex-col items-center p-3 bg-white rounded-xl border border-gray-200 hover:border-primary-300 hover:bg-primary-50 transition-colors text-center"
              >
                <span class="text-xl mb-1" aria-hidden="true">📄</span>
                <span class="text-[10px] font-bold uppercase tracking-wider text-gray-400">{labels.resources.tor}</span>
              </a>
              <a 
                href={`/docs/projects/${project.slug}/financial.pdf`} 
                target="_blank"
                rel="noopener"
                class="flex flex-col items-center p-3 bg-white rounded-xl border border-gray-200 hover:border-primary-300 hover:bg-primary-50 transition-colors text-center"
              >
                <span class="text-xl mb-1" aria-hidden="true">💰</span>
                <span class="text-[10px] font-bold uppercase tracking-wider text-gray-400">{labels.resources.financials}</span>
              </a>
              <a 
                href={`/docs/projects/${project.slug}/report.pdf`} 
                target="_blank"
                rel="noopener"
                class="flex flex-col items-center p-3 bg-white rounded-xl border border-gray-200 hover:border-primary-300 hover:bg-primary-50 transition-colors text-center"
              >
                <span class="text-xl mb-1" aria-hidden="true">📊</span>
                <span class="text-[10px] font-bold uppercase tracking-wider text-gray-400">{labels.resources.completionReport}</span>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </Section>
</PageLayout>
