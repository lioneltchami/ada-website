---
import PageLayout from "../../layouts/PageLayout.astro";
import Section from "../../components/layout/Section.astro";
import { getProjects, type SanityProject } from '../../lib/sanity';
import { projects as fallbackProjects } from '../../data/projects';

export async function getStaticPaths() {
  let projectData;
  try {
    const sanityProjects = await getProjects();
    if (sanityProjects?.length) {
      projectData = sanityProjects.map((p: SanityProject) => ({
        slug: p.slug.current, title: p.title, location: p.location, status: p.status,
        description: p.description, beneficiaries: p.beneficiaries, goal: p.goalAmount, raised: p.raisedAmount,
      }));
    } else { projectData = fallbackProjects; }
  } catch { projectData = fallbackProjects; }

  return projectData.map((project) => ({ params: { slug: project.slug }, props: { project } }));
}

const { project } = Astro.props;
const progress = Math.min(100, (project.raised / project.goal) * 100);
const costPerBeneficiary = project.beneficiaries > 0 ? Math.round(project.raised / project.beneficiaries) : 0;

// Split description into paragraphs for better readability
const paragraphs = project.description.split(/[.;]\s*(?=[A-Z(])/).filter(Boolean).reduce((acc: string[][], sentence: string, i: number) => {
  const paraIndex = Math.floor(i / 3);
  if (!acc[paraIndex]) acc[paraIndex] = [];
  acc[paraIndex].push(sentence.trim());
  return acc;
}, [] as string[][]).map((sentences: string[]) => sentences.join('. ') + (sentences[sentences.length - 1].endsWith('.') ? '' : '.'));
---

<PageLayout title={project.title} description={project.description.slice(0, 160)}>
  <!-- Hero -->
  <section class="relative py-16 md:py-24 bg-gradient-to-br from-primary-800 via-primary-700 to-primary-900 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/projects" class="inline-flex items-center text-sm text-white/70 hover:text-white mb-6 transition-colors">
        ← Back to All Projects
      </a>
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <span class:list={["px-3 py-1 text-xs font-semibold rounded-full", project.status === "active" ? "bg-green-400/20 text-green-200 border border-green-400/30" : project.status === "completed" ? "bg-gray-400/20 text-gray-200 border border-gray-400/30" : "bg-yellow-400/20 text-yellow-200 border border-yellow-400/30"]}>
          {project.status === "active" ? "● Active" : project.status === "completed" ? "✓ Completed" : "⏸ Paused"}
        </span>
        <span class="text-sm text-white/70">📍 {project.location}</span>
        <span class="text-sm text-white/70">👥 {project.beneficiaries} beneficiaries</span>
      </div>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold leading-tight">{project.title}</h1>
      <p class="mt-4 text-lg text-white/80 max-w-2xl">Serving vulnerable communities in {project.location}, Cameroon</p>
    </div>
  </section>

  <!-- Quick Stats Bar -->
  <div class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
        <div>
          <p class="text-xl font-bold text-primary-700">{project.beneficiaries}</p>
          <p class="text-xs text-gray-500">People Helped</p>
        </div>
        <div>
          <p class="text-xl font-bold text-primary-700">${project.raised.toLocaleString()}</p>
          <p class="text-xs text-gray-500">Raised So Far</p>
        </div>
        <div>
          <p class="text-xl font-bold text-primary-700">{Math.round(progress)}%</p>
          <p class="text-xs text-gray-500">Funded</p>
        </div>
        <div>
          <p class="text-xl font-bold text-primary-700">${costPerBeneficiary}</p>
          <p class="text-xs text-gray-500">Cost Per Person</p>
        </div>
      </div>
    </div>
  </div>

  <Section background="white" padding="lg">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Main Content -->
      <div class="lg:col-span-2">
        <!-- The Problem & Our Response -->
        <div class="space-y-6">
          <h2 class="text-2xl font-heading font-bold text-gray-900">About This Project</h2>
          <div class="prose prose-gray max-w-none space-y-4">
            {paragraphs.map((para) => (
              <p class="text-gray-600 leading-relaxed">{para}</p>
            ))}
          </div>
        </div>

        <!-- Impact Metrics -->
        <div class="mt-10">
          <h3 class="text-lg font-heading font-semibold text-gray-900">Impact at a Glance</h3>
          <div class="mt-4 grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="p-4 bg-primary-50 rounded-xl border border-primary-100 text-center">
              <p class="text-2xl font-bold text-primary-700">{project.beneficiaries}</p>
              <p class="text-xs text-gray-600">Direct Beneficiaries</p>
            </div>
            <div class="p-4 bg-primary-50 rounded-xl border border-primary-100 text-center">
              <p class="text-2xl font-bold text-primary-700">{project.location}</p>
              <p class="text-xs text-gray-600">Location</p>
            </div>
            <div class="p-4 bg-primary-50 rounded-xl border border-primary-100 text-center">
              <p class="text-2xl font-bold text-primary-700">${costPerBeneficiary}</p>
              <p class="text-xs text-gray-600">Per Beneficiary</p>
            </div>
          </div>
        </div>

        <!-- Sustainability -->
        <div class="mt-10 p-6 bg-gradient-to-r from-primary-50 to-accent-50 rounded-2xl border border-primary-100">
          <h3 class="text-lg font-heading font-semibold text-gray-900">♻️ Sustainability</h3>
          <p class="mt-2 text-sm text-gray-700 leading-relaxed">
            This program is designed to outlive external funding. Beneficiaries gain skills and networks that generate income independently. Graduates become mentors for future cohorts, creating a self-sustaining cycle of empowerment. When funding ends, the skills, community structures, and local leadership remain.
          </p>
        </div>

        <!-- Gender Impact -->
        <div class="mt-6 p-6 bg-accent-50 rounded-2xl border border-accent-100">
          <h3 class="text-lg font-heading font-semibold text-gray-900">🎯 Gender Equality</h3>
          <p class="mt-2 text-sm text-gray-700 leading-relaxed">
            85% of this project's beneficiaries are women and girls. Our approach directly advances gender equality by restoring economic agency, providing education access, and building pathways to financial independence for the most marginalized.
          </p>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Fundraising Card -->
        <div class="p-6 bg-gray-50 rounded-2xl border border-gray-200 sticky top-24">
          <h3 class="text-lg font-semibold text-gray-900">Fundraising Progress</h3>
          <div class="mt-4">
            <div class="flex justify-between text-sm mb-2">
              <span class="font-bold text-gray-900">${project.raised.toLocaleString()}</span>
              <span class="text-gray-500">of ${project.goal.toLocaleString()}</span>
            </div>
            <div class="w-full h-4 bg-gray-200 rounded-full overflow-hidden" role="progressbar" aria-valuenow={Math.round(progress)} aria-valuemin="0" aria-valuemax="100" aria-label="Fundraising progress">
              <div class="h-full bg-gradient-to-r from-primary-500 to-primary-400 rounded-full transition-all" style={`width: ${progress}%`}></div>
            </div>
            <p class="mt-2 text-sm text-gray-600">{Math.round(progress)}% funded</p>
            <p class="mt-1 text-xs text-gray-500">${(project.goal - project.raised).toLocaleString()} still needed</p>
          </div>

          <a href={`/donate?project=${project.slug}`} class="mt-6 block w-full text-center px-4 py-3.5 text-base font-semibold text-white bg-secondary-500 rounded-xl hover:bg-secondary-600 transition-colors shadow-md shadow-secondary-500/20">
            Support This Project
          </a>

          <div class="mt-4 text-center">
            <p class="text-xs text-gray-500">🔒 Secure · 80% to programs · Receipt emailed</p>
          </div>
        </div>

        <!-- Quick Facts -->
        <div class="p-6 bg-white rounded-2xl border border-gray-200">
          <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider">Quick Facts</h3>
          <dl class="mt-4 space-y-3">
            <div class="flex justify-between">
              <dt class="text-xs text-gray-500">Status</dt>
              <dd class="text-xs font-medium text-gray-900">{project.status === "active" ? "Active" : project.status === "completed" ? "Completed" : "Paused"}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-xs text-gray-500">Location</dt>
              <dd class="text-xs font-medium text-gray-900">{project.location}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-xs text-gray-500">Beneficiaries</dt>
              <dd class="text-xs font-medium text-gray-900">{project.beneficiaries} people</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-xs text-gray-500">Cost per person</dt>
              <dd class="text-xs font-medium text-gray-900">${costPerBeneficiary}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-xs text-gray-500">Gender focus</dt>
              <dd class="text-xs font-medium text-gray-900">85% women & girls</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-xs text-gray-500">Admin overhead</dt>
              <dd class="text-xs font-medium text-gray-900">5%</dd>
            </div>
          </dl>
        </div>

        <!-- Share -->
        <div class="p-6 bg-white rounded-2xl border border-gray-200">
          <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider">Share This Project</h3>
          <div class="mt-3 flex gap-2">
            <a href={`https://twitter.com/intent/tweet?text=Support ${encodeURIComponent(project.title)} in Cameroon&url=https://apotidev.org/projects/${project.slug}`} target="_blank" rel="noopener" class="flex-1 text-center px-3 py-2 text-xs font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">X</a>
            <a href={`https://www.facebook.com/sharer/sharer.php?u=https://apotidev.org/projects/${project.slug}`} target="_blank" rel="noopener" class="flex-1 text-center px-3 py-2 text-xs font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">Facebook</a>
            <a href={`https://wa.me/?text=Support ${encodeURIComponent(project.title)} https://apotidev.org/projects/${project.slug}`} target="_blank" rel="noopener" class="flex-1 text-center px-3 py-2 text-xs font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">WhatsApp</a>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- Other Projects -->
  <Section background="gray" padding="md">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-xl font-heading font-bold text-gray-900">Explore More Projects</h2>
      <p class="mt-2 text-sm text-gray-600">Every project addresses a different dimension of vulnerability in Cameroon.</p>
      <div class="mt-4 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/projects" class="px-5 py-2.5 text-sm font-medium text-primary-700 border border-primary-200 rounded-lg hover:bg-primary-50 transition-colors">View All Projects</a>
        <a href="/transparency" class="px-5 py-2.5 text-sm font-medium text-gray-600 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors">See Our Impact Data</a>
      </div>
    </div>
  </Section>
</PageLayout>
